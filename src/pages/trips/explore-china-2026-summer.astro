---
import Layout from '../../layouts/Layout.astro';
import {
  currentTrip,
  faq,
  included,
  notIncluded,
  cityGuides,
  itinerary,
  recommendedVideos,
  site,
} from '../../data/site';
---
<Layout title={currentTrip.title} lang="en" alternateHref="/zh/trips/explore-china-2026-summer" alternateLabel="中文" darkNav={true}>

  <!-- Hero Banner -->
  <div class="trip-hero">
    <img
      src="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1600&q=80"
      alt="Beijing Forbidden City aerial view"
      class="trip-hero__img"
    />
    <div class="trip-hero__overlay">
      <h1 class="trip-hero__title">{currentTrip.title}</h1>
      <p class="trip-hero__sub">{currentTrip.summary}</p>
    </div>
  </div>

  <!-- Overview -->
  <section id="overview" class="section card tone-sand" style="padding:34px;">
    <div class="grid cols-4" style="margin-top:14px;">
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Route</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.subtitle}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Departure</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.departureWindow}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Application closes</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.applicationDeadline}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">Group size</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.groupSize}</p></article>
    </div>

    <div class="grid cols-2" style="margin-top:18px;">
      <article class="card" style="background:#fff;">
        <p class="label">Price</p>
        <p style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:720; margin-top:6px;">{currentTrip.priceCad}</p>
        <p class="muted" style="margin-top:8px;">Designed as a high-support student route with a small-group feel, not a mass-tour product.</p>
      </article>
      <article class="card" style="background:#fff;">
        <p class="label">Who it suits best</p>
        <p class="muted" style="margin-top:6px; line-height:1.8;">Students and young travelers who want clear structure, iconic cities, and enough local/social context to make the route feel alive rather than transactional.</p>
      </article>
    </div>

    <p class="muted" style="text-align:center; margin-top:10px;">Contact: {site.email}</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; justify-content:center;">
      <a class="btn btn-primary" href="#register">Apply</a>
      <a class="btn btn-secondary" href="/handbook">Open participant handbook</a>
    </div>
  </section>

  <!-- Itinerary -->
  <section id="itinerary" class="section card tone-dark">
    <h2 class="section-title">10-day route at a glance</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px; background:#fff; color:#151515; border-color:#ece7dd;">
          <p class="pill" style="margin-bottom:8px;">{d.day}</p>
          <h3 style="margin-bottom:6px;">{d.city} · {d.title}</h3>
          <p class="muted" style="margin:0; color:#545a60;">{d.plan}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- City Guides -->
  {cityGuides.map((city, idx) => (
    <section class={`section card ${idx % 2 === 0 ? 'tone-rose' : 'tone-blue'}`} id={city.city.toLowerCase()}>
      <div class="grid cols-2" style="align-items:start; gap:20px;">
        <article>
          <p class="pill">{city.cityZh}</p>
          <h2 class="section-title" style="margin-bottom:12px;">{city.city}</h2>
          <p class="muted" style="font-size:1.05rem; line-height:1.9;">{city.intro}</p>
        </article>
        <article class="card" style="padding:0; overflow:hidden; background:#fff;">
          <img class="photo media-wide" src={city.heroImage} alt={city.heroAlt} />
        </article>
      </div>

      <div class="grid cols-3" style="margin-top:18px;">
        {city.explore.map((spot) => (
          <article class="card" style="background:#fff;">
            <p class="label">We will explore</p>
            <h3 style="margin:8px 0 10px;">{spot.title}</h3>
            <p class="muted" style="margin:0; line-height:1.8;">{spot.description}</p>
          </article>
        ))}
      </div>

      <article class="card" style="margin-top:18px; background:#fff;">
        <p class="label">Food highlight</p>
        <h3 style="margin:8px 0 10px;">{city.foodHighlight.title}</h3>
        <p class="muted" style="margin:0; line-height:1.8;">{city.foodHighlight.description}</p>
      </article>

      <div class="grid cols-4" style="margin-top:18px;">
        {city.gallery.map((image, imageIdx) => (
          <figure class="card" style="margin:0; padding:0; overflow:hidden; background:#fff;">
            <img class="photo media-card" src={image} alt={`${city.city} travel reference ${imageIdx + 1}`} loading={idx === 0 && imageIdx < 2 ? 'eager' : 'lazy'} />
          </figure>
        ))}
      </div>
    </section>
  ))}

  <!-- Included / Not Included -->
  <section class="section grid cols-2">
    <article class="card"><h2 style="font-size:30px;">Included</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{included.map((item) => <li>{item}</li>)}</ul></article>
    <article class="card"><h2 style="font-size:30px;">Not included</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncluded.map((item) => <li>{item}</li>)}</ul></article>
  </section>

  <!-- Pricing -->
  <section class="section card tone-sand">
    <h2 class="section-title">Pricing & booking rhythm</h2>
    <div class="grid cols-3">
      <article class="card" style="background:#fff;"><h3>Deposit</h3><p class="muted" style="margin:0;">Reserve your seat with a CAD $300 deposit after fit confirmation and follow-up email.</p></article>
      <article class="card" style="background:#fff;"><h3>Balance</h3><p class="muted" style="margin:0;">Remaining balance is due 30 days before departure unless your confirmation pack states otherwise.</p></article>
      <article class="card" style="background:#fff;"><h3>Changes & cancellation</h3><p class="muted" style="margin:0;">Detailed refund/change rules are sent in the formal booking pack so you can review them before committing the full balance.</p></article>
    </div>
  </section>

  <!-- Videos -->
  <section class="section card tone-blue">
    <h2 class="section-title">Video references before you decide</h2>
    <div class="grid cols-3">
      {recommendedVideos.map((video) => (
        <article class="card" style="background:#fff;">
          <p class="label">Watch</p>
          <h3 style="margin:8px 0 6px;">{video.title}</h3>
          <p class="muted" style="margin:0 0 10px;">{video.creator}</p>
          <p class="muted" style="margin:0 0 12px; line-height:1.8;">{video.note}</p>
          <a class="text-link" href={video.url} target="_blank">Open video ↗</a>
        </article>
      ))}
    </div>
  </section>

  <!-- FAQ (accordion, consistent with homepage) -->
  <section id="faq" class="faq">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow">FAQ</p>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>
      <div class="faq__list">
        {faq.map((f, i) => (
          <div class="faq__item" id={`trip-faq-${i}`}>
            <button class="faq__q" aria-expanded="false" aria-controls={`trip-faq-answer-${i}`}>
              <span>{f.q}</span>
              <svg class="faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="faq__a" id={`trip-faq-answer-${i}`} role="region" aria-labelledby={`trip-faq-${i}`}>
              <div class="faq__a-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Apply -->
  <section id="register" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">Apply for this program</h2>
    <p class="muted" style="text-align:center; max-width:760px; margin:0 auto 20px;">Tell us who you are, why this route fits, and how to reach you. We review applications personally rather than treating this as an instant checkout flow.</p>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="New Explore China application lead" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label for="name">Full name</label><input id="name" name="name" required /></div>
      <div class="field"><label for="email">Email</label><input id="email" type="email" name="email" required /></div>
      <div class="field"><label for="phone">WhatsApp / Phone (optional)</label><input id="phone" name="phone" /></div>
      <div class="field"><label for="city">Current city</label><input id="city" name="city" /></div>
      <div class="field" style="grid-column:1 / -1;"><label for="goal">Why do you want this trip?</label><textarea id="goal" name="goal" required></textarea></div>
      <div style="grid-column:1 / -1; display:flex; gap:10px; justify-content:center;"><button class="btn btn-primary" type="submit">Submit Application</button></div>
    </form>
    <p class="muted" style="text-align:center; margin-top:10px;">Questions? Email {site.email}</p>
  </section>
</Layout>

<style>
.trip-hero {
  position: relative;
  height: 420px;
  overflow: hidden;
}
.trip-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.trip-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 2.5rem;
  text-align: center;
}
.trip-hero__title {
  color: #fff;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  font-family: var(--font-display);
  line-height: 1.1;
  margin-bottom: 0.75rem;
}
.trip-hero__sub {
  color: rgba(255,255,255,0.85);
  font-size: 1.1rem;
  max-width: 640px;
  line-height: 1.7;
}
</style>

<script is:inline>
  document.querySelectorAll('.faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq__q').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      if (!expanded) btn.setAttribute('aria-expanded', 'true');
    });
  });
</script>
