---
import Layout from '../../layouts/Layout.astro';
import {
  currentTrip,
  faq,
  included,
  notIncluded,
  cityGuides,
  itinerary,
  recommendedVideos,
} from '../../data/site';

const tripStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'TouristTrip',
    name: currentTrip.title,
    description:
      'A 10-day student-led China summer trip from Canada covering Shanghai, Suzhou, Hangzhou, and Beijing.',
    itinerary: itinerary.map((day) => `${day.day}: ${day.city} - ${day.title}`),
    touristType: 'Students and young travelers from Canada',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.explorechina.ca/' },
      { '@type': 'ListItem', position: 2, name: 'Trip', item: 'https://www.explorechina.ca/trips/explore-china-2026-summer' },
    ],
  },
];
---
<Layout
  title={currentTrip.title}
  description="Explore the 2026 student-led China summer trip from Canada, with a 10-day route through Shanghai, Suzhou, Hangzhou, and Beijing."
  lang="en"
  alternateHref="/zh/trips/explore-china-2026-summer"
  alternateLabel="中文"
  canonical="/trips/explore-china-2026-summer"
  structuredData={tripStructuredData}
  darkNav={true}
>

  <div class="trip-hero">
    <img
      src="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1600&q=80"
      alt="Beijing Forbidden City aerial view"
      class="trip-hero__img"
    />
    <div class="trip-hero__overlay">
      <h1 class="trip-hero__title">{currentTrip.title}</h1>
      <p class="trip-hero__sub">{currentTrip.summary}</p>
    </div>
  </div>

  <section id="overview" class="trip-strip">
    <div class="trip-strip__inner">
      <div class="trip-strip__facts">
        <div class="trip-strip__fact"><span class="trip-strip__label">Route</span><span class="trip-strip__val">{currentTrip.subtitle}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">Departure</span><span class="trip-strip__val">{currentTrip.departureWindow}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">Price</span><span class="trip-strip__val trip-strip__val--price">{currentTrip.priceCad}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">Group</span><span class="trip-strip__val">{currentTrip.groupSize}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">Deadline</span><span class="trip-strip__val">{currentTrip.applicationDeadline}</span></div>
      </div>
      <div class="trip-strip__actions">
        <a class="btn btn-secondary" href="/handbook">Handbook</a>
      </div>
    </div>
  </section>

  <section id="who-is-this-for" class="section" style="padding: 4rem 2rem;">
    <div style="max-width:48rem; margin:0 auto;">
      <h2 style="font-size:clamp(20px,3vw,30px); font-weight:700; font-family:var(--font-display); line-height:1.2; margin-bottom:1.25rem;">You don't need to know anything about China to come.</h2>
      <p class="muted" style="font-size:17px; line-height:1.85; margin-bottom:1rem;">No Mandarin. No experience. And all the stuff that sounds complicated — VPNs, payments, getting around — we've already figured out so you don't have to.</p>
      <p class="muted" style="font-size:17px; line-height:1.85; margin-bottom:1rem;">We were all first-timers once. All we ask is that you come with an open mind and a bit of curiosity.</p>
      <p class="muted" style="font-size:17px; line-height:1.85; padding-bottom:1.5rem;">That's genuinely enough.</p>
    </div>
  </section>

  <section id="itinerary" class="section card tone-sand">
    <h2 class="section-title">10-day route at a glance</h2>
    <div class="trip-timeline">
      {itinerary.map((d) => (
        <div class="trip-timeline__row">
          <div class="trip-timeline__day">{d.day}</div>
          <div class="trip-timeline__dot"></div>
          <div class="trip-timeline__content">
            <strong class="trip-timeline__city">{d.city}</strong>
            <span class="trip-timeline__title">{d.title}</span>
            <p class="trip-timeline__plan">{d.plan}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section card tone-blue city-tabs-section" id="city-guides" data-city-tabs>
    <div class="city-tabs-section__header">
      <p class="section-eyebrow">City Guide Tabs</p>
      <h2 class="section-title">Meet the cities before you arrive</h2>
      <p class="section-sub">Switch tabs in place to get the cultural story, the on-the-ground feeling, and a few practical anchors for each stop on the route.</p>
    </div>

    <div class="city-tabs__nav" role="tablist" aria-label="City guide tabs">
      {cityGuides.map((city, idx) => (
        <button
          type="button"
          class={`city-tabs__tab ${idx === 0 ? 'is-active' : ''}`}
          id={`city-tab-${city.city.toLowerCase()}`}
          role="tab"
          aria-selected={idx === 0 ? 'true' : 'false'}
          aria-controls={`city-panel-${city.city.toLowerCase()}`}
          data-city-tab={city.city.toLowerCase()}
          tabindex={idx === 0 ? '0' : '-1'}
        >
          <span>{city.city}</span>
          <span class="city-tabs__tab-sub">{city.cityZh}</span>
        </button>
      ))}
    </div>

    {cityGuides.map((city, idx) => (
      <article
        class={`city-tabs__panel ${idx === 0 ? 'is-active' : ''}`}
        id={`city-panel-${city.city.toLowerCase()}`}
        role="tabpanel"
        aria-labelledby={`city-tab-${city.city.toLowerCase()}`}
        hidden={idx !== 0}
        data-city-panel={city.city.toLowerCase()}
      >
        <div class="city-tabs__panel-grid">
          <figure class="card city-tabs__hero">
            <img class="photo media-wide" src={city.heroImage} alt={city.heroAlt} loading={idx === 0 ? 'eager' : 'lazy'} />
          </figure>
          <div class="city-tabs__story">
            <p class="pill">{city.city} · {city.cityZh}</p>
            <h3 class="city-tabs__title">Why this city matters on the route</h3>
            <p class="city-tabs__lead">{city.context}</p>
            <p class="city-tabs__text">{city.feeling}</p>
          </div>
        </div>

        <div class="city-tabs__highlights">
          {city.explore.slice(0, 4).map((spot) => (
            <article class="card city-tabs__highlight" style={spot.image ? `--highlight-bg: url(${spot.image})` : ''}>
              {spot.image && <div class="highlight-img" aria-hidden="true"></div>}
              <div class="highlight-content">
                <p class="label">Key highlight</p>
                <h4>{spot.title}</h4>
                <p class="muted">{spot.description}</p>
              </div>
            </article>
          ))}
        </div>
      </article>
    ))}
  </section>

  <section class="section incl-grid">
    <article class="incl-card incl-card--yes">
      <h2 class="incl-card__title">Included</h2>
      <ul class="incl-list">
        {included.map((item) => (
          <li class="incl-item"><i class="incl-icon incl-icon--yes">✓</i><span>{item}</span></li>
        ))}
      </ul>
    </article>
    <article class="incl-card incl-card--no">
      <h2 class="incl-card__title">Not included</h2>
      <ul class="incl-list">
        {notIncluded.map((item) => (
          <li class="incl-item"><i class="incl-icon incl-icon--no">×</i><span>{item}</span></li>
        ))}
      </ul>
    </article>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">Video references before you decide</h2>
    <div class="grid cols-3 video-grid">
      {recommendedVideos.map((video) => {
        const ytId = video.url.match(/[?&]v=([^&]+)/)?.[1] || '';
        return (
          <a href={video.url} target="_blank" rel="noopener" class="video-card">
            <div class="video-card__thumb">
              <img src={`https://img.youtube.com/vi/${ytId}/hqdefault.jpg`} alt={video.title} loading="lazy" />
              <div class="video-card__play">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.6)"/><path d="M19 15l14 9-14 9V15z" fill="#fff"/></svg>
              </div>
            </div>
            <div class="video-card__info">
              <h3 class="video-card__title">{video.title}</h3>
              <p class="video-card__creator">{video.creator}</p>
              <p class="video-card__note">{video.note}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- SEO context — visually subtle, content-rich for search engines -->
  <section class="section" style="padding: 1.5rem 2rem 0;">
    <div style="max-width:54rem; margin:0 auto; border-top:1px solid #e8e5e0; padding-top:1.5rem;">
      <p style="font-size:13px; line-height:1.9; color:#9a9590; text-align:center;">Planning a China trip from Toronto or elsewhere in Canada? Start with the <a href="/handbook" style="color:#b8524a;">handbook</a>, then check the <a href="/about" style="color:#b8524a;">team background</a> and <a href="/privacy" style="color:#b8524a;">privacy policy</a>.</p>
    </div>
  </section>

  <section id="faq" class="faq">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow">FAQ</p>
        <h2 class="section-title">Frequently Asked Questions</h2>
      </div>
      <div class="faq__list">
        {faq.map((f, i) => (
          <div class="faq__item" id={`trip-faq-${i}`}>
            <button class="faq__q" aria-expanded="false" aria-controls={`trip-faq-answer-${i}`}>
              <span>{f.q}</span>
              <svg class="faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="faq__a" id={`trip-faq-answer-${i}`} role="region" aria-labelledby={`trip-faq-${i}`}>
              <div class="faq__a-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
.trip-hero {
  position: relative;
  height: 420px;
  overflow: hidden;
}
.trip-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.trip-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 2.5rem;
  text-align: center;
}
.trip-hero__title {
  color: #fff;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  font-family: var(--font-display);
  line-height: 1.1;
  margin-bottom: 0.75rem;
}
.trip-hero__sub {
  color: rgba(255,255,255,0.85);
  font-size: 1.1rem;
  max-width: 640px;
  line-height: 1.7;
}
</style>

<script is:inline>
  document.querySelectorAll('.faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq__q').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      if (!expanded) btn.setAttribute('aria-expanded', 'true');
    });
  });

  document.querySelectorAll('[data-city-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll('[data-city-tab]'));
    const panels = Array.from(root.querySelectorAll('[data-city-panel]'));

    const activateTab = (key) => {
      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-city-tab') === key;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
        tab.setAttribute('tabindex', active ? '0' : '-1');
      });

      panels.forEach((panel) => {
        const active = panel.getAttribute('data-city-panel') === key;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activateTab(tab.getAttribute('data-city-tab')));
      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        event.preventDefault();
        const nextIndex = event.key === 'ArrowRight'
          ? (index + 1) % tabs.length
          : (index - 1 + tabs.length) % tabs.length;
        const nextTab = tabs[nextIndex];
        nextTab.focus();
        activateTab(nextTab.getAttribute('data-city-tab'));
      });
    });
  });

  /* ── Mobile: IntersectionObserver reveals highlight images on scroll ── */
  if (window.matchMedia('(max-width: 768px)').matches || 'ontouchstart' in window) {
    const highlightCards = document.querySelectorAll('.city-tabs__highlight');
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
        } else {
          e.target.classList.remove('in-view');
        }
      });
    }, { threshold: 0.5 });
    highlightCards.forEach((card) => io.observe(card));
  }
</script>
