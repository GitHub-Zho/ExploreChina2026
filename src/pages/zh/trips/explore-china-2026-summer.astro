---
import Layout from '../../../layouts/Layout.astro';
import {
  currentTrip,
  faqZh,
  includedZh,
  notIncludedZh,
  cityGuides,
  itinerary,
  recommendedVideos,
} from '../../../data/site';
---
<Layout title={currentTrip.titleZh} lang="zh" alternateHref="/trips/explore-china-2026-summer" alternateLabel="EN" darkNav={true}>

  <!-- Hero Banner -->
  <div class="trip-hero">
    <img
      src="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1600&q=80"
      alt="北京故宫鸟瞰"
      class="trip-hero__img"
    />
    <div class="trip-hero__overlay">
      <h1 class="trip-hero__title">{currentTrip.titleZh}</h1>
      <p class="trip-hero__sub">{currentTrip.summaryZh}</p>
    </div>
  </div>

  <!-- Overview — compact info strip -->
  <section id="overview" class="trip-strip">
    <div class="trip-strip__inner">
      <div class="trip-strip__facts">
        <div class="trip-strip__fact"><span class="trip-strip__label">路线</span><span class="trip-strip__val">{currentTrip.subtitleZh}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">出发</span><span class="trip-strip__val">{currentTrip.departureWindowZh}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">价格</span><span class="trip-strip__val trip-strip__val--price">{currentTrip.priceCadZh}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">人数</span><span class="trip-strip__val">{currentTrip.groupSizeZh}</span></div>
        <div class="trip-strip__fact"><span class="trip-strip__label">截止</span><span class="trip-strip__val">{currentTrip.applicationDeadlineZh}</span></div>
      </div>
      <div class="trip-strip__actions">
        <a class="btn btn-secondary" href="/zh/handbook">手册</a>
      </div>
    </div>
  </section>

  <!-- Who is this for -->
  <section id="who-is-this-for" class="section" style="padding: 4rem 2rem;">
    <div class="max-w-3xl mx-auto" style="max-width:48rem; margin-left:auto; margin-right:auto;">
      <h2 style="font-size:clamp(20px,3vw,30px); font-weight:700; font-family:var(--font-display); line-height:1.2; margin-bottom:1.25rem;">你不需要了解中国，也可以来。</h2>
      <p class="muted" style="font-size:17px; line-height:1.85; margin-bottom:1rem;">不需要会中文，不需要有经验。那些听起来很复杂的事——翻墙、支付、出行——我们都已经帮你搞定了。</p>
      <p class="muted" style="font-size:17px; line-height:1.85; margin-bottom:1rem;">我们每个人都是第一次去的时候什么都不懂。你只需要带着好奇心和开放的态度就够了。</p>
      <p class="muted" style="font-size:17px; line-height:1.85; padding-bottom:1.5rem;">真的，这就够了。</p>
    </div>
  </section>

  <!-- Itinerary — compact timeline -->
  <section id="itinerary" class="section card tone-sand">
    <h2 class="section-title">10天路线一览</h2>
    <div class="trip-timeline">
      {itinerary.map((d) => (
        <div class="trip-timeline__row">
          <div class="trip-timeline__day">{d.dayZh}</div>
          <div class="trip-timeline__dot"></div>
          <div class="trip-timeline__content">
            <strong class="trip-timeline__city">{d.cityZh}</strong>
            <span class="trip-timeline__title">{d.titleZh}</span>
            <p class="trip-timeline__plan">{d.planZh}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- City Guides -->
  <section class="section card tone-blue city-tabs-section" id="city-guides" data-city-tabs>
    <div class="city-tabs-section__header">
      <p class="section-eyebrow">城市导览 Tabs</p>
      <h2 class="section-title">先在页面里认识这几座城市</h2>
      <p class="section-sub">点击标签即可原地切换内容，用更有人味的故事、感受和几个关键亮点，提前建立对每一站的熟悉感。</p>
    </div>

    <div class="city-tabs__nav" role="tablist" aria-label="城市导览标签">
      {cityGuides.map((city, idx) => (
        <button
          type="button"
          class={`city-tabs__tab ${idx === 0 ? 'is-active' : ''}`}
          id={`city-tab-${city.city.toLowerCase()}`}
          role="tab"
          aria-selected={idx === 0 ? 'true' : 'false'}
          aria-controls={`city-panel-${city.city.toLowerCase()}`}
          data-city-tab={city.city.toLowerCase()}
          tabindex={idx === 0 ? '0' : '-1'}
        >
          <span>{city.cityZh}</span>
          <span class="city-tabs__tab-sub">{city.city}</span>
        </button>
      ))}
    </div>

    {cityGuides.map((city, idx) => (
      <article
        class={`city-tabs__panel ${idx === 0 ? 'is-active' : ''}`}
        id={`city-panel-${city.city.toLowerCase()}`}
        role="tabpanel"
        aria-labelledby={`city-tab-${city.city.toLowerCase()}`}
        hidden={idx !== 0}
        data-city-panel={city.city.toLowerCase()}
      >
        <div class="city-tabs__panel-grid">
          <figure class="card city-tabs__hero">
            <img class="photo media-wide" src={city.heroImage} alt={city.heroAlt} loading={idx === 0 ? 'eager' : 'lazy'} />
          </figure>
          <div class="city-tabs__story">
            <p class="pill">{city.cityZh} · {city.city}</p>
            <h3 class="city-tabs__title">为什么这座城市值得你在路上认真感受</h3>
            <p class="city-tabs__lead">{city.contextZh}</p>
            <p class="city-tabs__text">{city.feelingZh}</p>
          </div>
        </div>

        <div class="city-tabs__highlights">
          {city.explore.slice(0, 4).map((spot) => (
            <article class="card city-tabs__highlight">
              <p class="label">关键亮点</p>
              <h4>{spot.titleZh}</h4>
              <p class="muted">{spot.descriptionZh}</p>
            </article>
          ))}
        </div>
      </article>
    ))}
  </section>

  <!-- Included / Not Included -->
  <section class="section incl-grid">
    <article class="incl-card incl-card--yes">
      <h2 class="incl-card__title">包含内容</h2>
      <ul class="incl-list">
        {includedZh.map((item) => (
          <li class="incl-item"><i class="incl-icon incl-icon--yes">✓</i><span>{item}</span></li>
        ))}
      </ul>
    </article>
    <article class="incl-card incl-card--no">
      <h2 class="incl-card__title">不包含内容</h2>
      <ul class="incl-list">
        {notIncludedZh.map((item) => (
          <li class="incl-item"><i class="incl-icon incl-icon--no">✗</i><span>{item}</span></li>
        ))}
      </ul>
    </article>
  </section>

  <!-- Videos -->
  <section class="section card tone-blue">
    <h2 class="section-title">出发前可以先看的视频</h2>
    <div class="grid cols-3 video-grid">
      {recommendedVideos.map((video) => {
        const ytId = video.url.match(/[?&]v=([^&]+)/)?.[1] || '';
        return (
          <a href={video.url} target="_blank" rel="noopener" class="video-card">
            <div class="video-card__thumb">
              <img src={`https://img.youtube.com/vi/${ytId}/hqdefault.jpg`} alt={video.titleZh} loading="lazy" />
              <div class="video-card__play">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.6)"/><path d="M19 15l14 9-14 9V15z" fill="#fff"/></svg>
              </div>
            </div>
            <div class="video-card__info">
              <h3 class="video-card__title">{video.titleZh}</h3>
              <p class="video-card__creator">{video.creator}</p>
              <p class="video-card__note">{video.noteZh}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- FAQ (accordion, consistent with homepage) -->
  <section id="faq" class="faq">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow">常见问题</p>
        <h2 class="section-title">常见问题解答</h2>
      </div>
      <div class="faq__list">
        {faqZh.map((f, i) => (
          <div class="faq__item" id={`trip-faq-${i}`}>
            <button class="faq__q" aria-expanded="false" aria-controls={`trip-faq-answer-${i}`}>
              <span>{f.q}</span>
              <svg class="faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="faq__a" id={`trip-faq-answer-${i}`} role="region" aria-labelledby={`trip-faq-${i}`}>
              <div class="faq__a-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


</Layout>

<style>
.trip-hero {
  position: relative;
  height: 420px;
  overflow: hidden;
}
.trip-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.trip-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 2.5rem;
  text-align: center;
}
.trip-hero__title {
  color: #fff;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  font-family: var(--font-display);
  line-height: 1.1;
  margin-bottom: 0.75rem;
}
.trip-hero__sub {
  color: rgba(255,255,255,0.85);
  font-size: 1.1rem;
  max-width: 640px;
  line-height: 1.7;
}
</style>

<script is:inline>
  document.querySelectorAll('.faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq__q').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      if (!expanded) btn.setAttribute('aria-expanded', 'true');
    });
  });

  document.querySelectorAll('[data-city-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll('[data-city-tab]'));
    const panels = Array.from(root.querySelectorAll('[data-city-panel]'));

    const activateTab = (key) => {
      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-city-tab') === key;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
        tab.setAttribute('tabindex', active ? '0' : '-1');
      });

      panels.forEach((panel) => {
        const active = panel.getAttribute('data-city-panel') === key;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activateTab(tab.getAttribute('data-city-tab')));
      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        event.preventDefault();
        const nextIndex = event.key === 'ArrowRight'
          ? (index + 1) % tabs.length
          : (index - 1 + tabs.length) % tabs.length;
        const nextTab = tabs[nextIndex];
        nextTab.focus();
        activateTab(nextTab.getAttribute('data-city-tab'));
      });
    });
  });
</script>
