---
import Layout from '../../../layouts/Layout.astro';
import {
  currentTrip,
  faqZh,
  includedZh,
  notIncludedZh,
  cityGuides,
  itinerary,
  highlightsZh,
  recommendedVideos,
  site,
} from '../../../data/site';
---
<Layout title={currentTrip.titleZh} lang="zh" alternateHref="/trips/explore-china-2026-summer" alternateLabel="EN">
  <section id="overview" class="section card tone-sand" style="padding:34px;">
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:12px; text-align:center;">{currentTrip.titleZh}</h1>
    <p class="muted section-sub" style="font-size:18px; margin-inline:auto; text-align:center;">{currentTrip.summaryZh}</p>

    <div class="grid cols-4" style="margin-top:14px;">
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">路线</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.subtitleZh}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">出发时间</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.departureWindowZh}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">报名截止</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.applicationDeadlineZh}</p></article>
      <article class="card" style="padding:14px; background:#fff;"><p class="label" style="margin:0">团队规模</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.groupSizeZh}</p></article>
    </div>

    <div class="grid cols-2" style="margin-top:18px;">
      <article class="card" style="background:#fff;">
        <p class="label">价格</p>
        <p style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:720; margin-top:6px;">{currentTrip.priceCadZh}</p>
        <p class="muted" style="margin-top:8px;">它更像一条小规模、高支持度的学生旅行路线，而不是标准化的大团产品。</p>
      </article>
      <article class="card" style="background:#fff;">
        <p class="label">适合谁</p>
        <p class="muted" style="margin-top:6px; line-height:1.8;">适合希望行程清晰、有代表性城市、又不想只有“打卡感”的学生与年轻旅行者。</p>
      </article>
    </div>

    <p class="muted" style="text-align:center; margin-top:10px;">联系邮箱：{site.email}</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; justify-content:center;">
      <a class="btn btn-primary" href="#register">立即报名</a>
      <a class="btn btn-secondary" href="/zh/handbook">查看参与者手册</a>
    </div>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">为什么这条路线执行起来更安心</h2>
    <div class="grid cols-2">
      {highlightsZh.map((item) => (
        <article class="card" style="background:#fff; display:flex; gap:12px; align-items:flex-start;">
          <span class="pill" style="margin:0;">保障</span>
          <p class="muted" style="margin:0;">{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="itinerary" class="section card tone-dark">
    <h2 class="section-title">10天路线一览</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px; background:#fff; color:#151515; border-color:#ece7dd;">
          <p class="pill" style="margin-bottom:8px;">{d.dayZh}</p>
          <h3 style="margin-bottom:6px;">{d.cityZh} · {d.titleZh}</h3>
          <p class="muted" style="margin:0; color:#545a60;">{d.planZh}</p>
        </article>
      ))}
    </div>
  </section>

  {cityGuides.map((city, idx) => (
    <section class={`section card ${idx % 2 === 0 ? 'tone-rose' : 'tone-blue'}`} id={city.city.toLowerCase()}>
      <div class="grid cols-2" style="align-items:start; gap:20px;">
        <article>
          <p class="pill">{city.city}</p>
          <h2 class="section-title" style="margin-bottom:12px;">{city.cityZh}</h2>
          <p class="muted" style="font-size:1.05rem; line-height:1.9;">{city.introZh}</p>
        </article>
        <article class="card" style="padding:0; overflow:hidden; background:#fff;">
          <img class="photo media-wide" src={city.heroImage} alt={city.heroAlt} />
        </article>
      </div>

      <div class="grid cols-3" style="margin-top:18px;">
        {city.explore.map((spot) => (
          <article class="card" style="background:#fff;">
            <p class="label">我们会体验</p>
            <h3 style="margin:8px 0 10px;">{spot.titleZh}</h3>
            <p class="muted" style="margin:0; line-height:1.8;">{spot.descriptionZh}</p>
          </article>
        ))}
      </div>

      <article class="card" style="margin-top:18px; background:#fff;">
        <p class="label">食物高光</p>
        <h3 style="margin:8px 0 10px;">{city.foodHighlight.titleZh}</h3>
        <p class="muted" style="margin:0; line-height:1.8;">{city.foodHighlight.descriptionZh}</p>
      </article>

      <div class="grid cols-4" style="margin-top:18px;">
        {city.gallery.map((image, imageIdx) => (
          <figure class="card" style="margin:0; padding:0; overflow:hidden; background:#fff;">
            <img class="photo media-card" src={image} alt={`${city.cityZh} 参考图片 ${imageIdx + 1}`} loading={idx === 0 && imageIdx < 2 ? 'eager' : 'lazy'} />
          </figure>
        ))}
      </div>
    </section>
  ))}

  <section class="section card tone-sand">
    <h2 class="section-title">价格与报名节奏</h2>
    <div class="grid cols-3">
      <article class="card" style="background:#fff;"><h3>订金</h3><p class="muted" style="margin:0;">完成初步沟通与匹配确认后，以 CAD $300 锁定名额。</p></article>
      <article class="card" style="background:#fff;"><h3>尾款</h3><p class="muted" style="margin:0;">默认在出发前 30 天完成尾款支付，若确认包有调整则以正式通知为准。</p></article>
      <article class="card" style="background:#fff;"><h3>退改</h3><p class="muted" style="margin:0;">完整退改说明会在正式报名确认包中发出，方便你在支付全款前先看清楚。</p></article>
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card"><h2 style="font-size:30px;">包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{includedZh.map((item) => <li>{item}</li>)}</ul></article>
    <article class="card"><h2 style="font-size:30px;">不包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncludedZh.map((item) => <li>{item}</li>)}</ul></article>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">出发前可以先看的视频</h2>
    <div class="grid cols-3">
      {recommendedVideos.map((video) => (
        <article class="card" style="background:#fff;">
          <p class="label">视频参考</p>
          <h3 style="margin:8px 0 6px;">{video.titleZh}</h3>
          <p class="muted" style="margin:0 0 10px;">{video.creator}</p>
          <p class="muted" style="margin:0 0 12px; line-height:1.8;">{video.noteZh}</p>
          <a class="text-link" href={video.url} target="_blank">打开视频 ↗</a>
        </article>
      ))}
    </div>
  </section>

  <section id="faq" class="section card tone-blue">
    <h2 class="section-title">常见问题</h2>
    {faqZh.map((f) => (
      <details style="margin-bottom:10px; border:1px solid #dce6f2; border-radius:12px; padding:12px; background:#fff;"><summary style="cursor:pointer; font-weight:700;">{f.q}</summary><p class="muted" style="margin:8px 0 0;">{f.a}</p></details>
    ))}
  </section>

  <section id="register" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">报名</h2>
    <p class="muted" style="text-align:center; max-width:760px; margin:0 auto 20px;">告诉我们你是谁、为什么想来，以及怎么联系你。我们会人工阅读每一份报名，而不是把它当成即时下单流程。</p>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="新的探索中国报名线索" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/zh/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label for="name">姓名</label><input id="name" name="name" required /></div>
      <div class="field"><label for="email">邮箱</label><input id="email" type="email" name="email" required /></div>
      <div class="field"><label for="phone">微信 / 电话（可选）</label><input id="phone" name="phone" /></div>
      <div class="field"><label for="city">所在城市</label><input id="city" name="city" /></div>
      <div class="field" style="grid-column:1 / -1;"><label for="goal">你为什么想参加这次行程？</label><textarea id="goal" name="goal" required></textarea></div>
      <div style="grid-column:1 / -1; display:flex; gap:10px; justify-content:center;"><button class="btn btn-primary" type="submit">提交报名</button></div>
    </form>
    <p class="muted" style="text-align:center; margin-top:10px;">有问题？请发邮件至 {site.email}</p>
  </section>
</Layout>
