---
import Layout from '../../../layouts/Layout.astro';
import {
  currentTrip,
  faqZh,
  includedZh,
  notIncludedZh,
  cityGuides,
  itinerary,
  highlightsZh,
  recommendedVideos,
  site,
} from '../../../data/site';
---
<Layout title={currentTrip.titleZh} lang="zh" alternateHref="/trips/explore-china-2026-summer" alternateLabel="EN" darkNav={true}>
  <section class="trip-hero">
    <img src={cityGuides[3].heroImage} alt={cityGuides[3].heroAlt} />
    <div class="trip-hero__overlay"></div>
    <div class="trip-hero__content">
      <div class="container">
        <p class="trip-hero__eyebrow">2026 夏季 · 学生路线</p>
        <h1 class="trip-hero__title">{currentTrip.titleZh}</h1>
        <p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-white/90 md:text-lg">
          {currentTrip.summaryZh}
        </p>
      </div>
    </div>
  </section>

  <section id="overview" class="py-20 bg-[var(--color-bg)]">
    <div class="container">
      <p class="section-eyebrow">概览</p>
      <h2 class="section-title">这条路线会是什么样</h2>
      <p class="section-sub">
        一条以四座代表性城市为骨架、兼顾文化体验、执行清晰度与同行氛围的学生友好型中国路线。
      </p>

      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="border border-stone-200 bg-white p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">路线</p>
          <p class="mt-2 text-lg font-semibold text-stone-900">{currentTrip.subtitleZh}</p>
        </article>
        <article class="border border-stone-200 bg-white p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">出发时间</p>
          <p class="mt-2 text-lg font-semibold text-stone-900">{currentTrip.departureWindowZh}</p>
        </article>
        <article class="border border-stone-200 bg-white p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">报名截止</p>
          <p class="mt-2 text-lg font-semibold text-stone-900">{currentTrip.applicationDeadlineZh}</p>
        </article>
        <article class="border border-stone-200 bg-white p-5">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">团队规模</p>
          <p class="mt-2 text-lg font-semibold text-stone-900">{currentTrip.groupSizeZh}</p>
        </article>
      </div>

      <div class="mt-6 grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
        <article class="border border-stone-200 bg-white p-6 md:p-8">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">价格</p>
          <p class="mt-3 text-3xl font-semibold leading-tight text-stone-900 md:text-4xl">{currentTrip.priceCadZh}</p>
          <p class="mt-4 text-stone-600 leading-8">
            这不是标准化大团产品，而是一条支持度更高、节奏更清楚、沟通更直接的小规模学生路线。
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a class="bg-red-700 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-red-800" href="#register">立即报名</a>
            <a class="border border-stone-300 px-6 py-3 text-sm font-semibold text-stone-900 transition-colors hover:border-stone-500" href="/zh/handbook">查看参与者手册</a>
          </div>
        </article>
        <article class="border border-stone-200 bg-white p-6 md:p-8">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">适合谁</p>
          <p class="mt-4 text-stone-600 leading-8">
            适合希望路线有结构、城市有代表性、体验不只有“打卡感”，同时又想保留真实在地氛围的学生与年轻旅行者。
          </p>
          <p class="mt-6 text-sm text-stone-500">有问题？{site.email}</p>
        </article>
      </div>
    </div>
  </section>

  <section id="itinerary" class="py-20 bg-stone-900 text-white">
    <div class="container">
      <p class="section-eyebrow text-red-300">行程</p>
      <h2 class="section-title text-white">10天路线一览</h2>
      <p class="max-w-3xl text-stone-300 leading-8">
        这条路线从上海的速度感出发，在江南段慢下来，最后在北京用最有历史重量感的地标完成收束。
      </p>
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {itinerary.map((d) => (
          <article class="border border-stone-700 bg-white p-5 text-stone-900">
            <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">{d.dayZh}</p>
            <h3 class="mt-3 text-2xl font-semibold">{d.cityZh} · {d.titleZh}</h3>
            <p class="mt-3 leading-7 text-stone-600">{d.planZh}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container">
      <p class="section-eyebrow">为什么更安心</p>
      <h2 class="section-title">有支持感，但不失旅行氛围</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {highlightsZh.map((item) => (
          <article class="border border-stone-200 bg-[var(--color-bg)] p-6">
            <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">体验里的支持</p>
            <p class="mt-3 leading-8 text-stone-700">{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {cityGuides.map((city, idx) => (
    <section class={idx % 2 === 0 ? 'py-20 bg-[var(--color-bg)]' : 'py-20 bg-white'} id={city.city.toLowerCase()}>
      <div class="container">
        <div class="grid items-start gap-8 lg:grid-cols-[0.95fr_1.05fr]">
          <article>
            <p class="section-eyebrow">{city.city}</p>
            <h2 class="section-title">{city.cityZh}</h2>
            <p class="text-lg leading-8 text-stone-600">{city.introZh}</p>
          </article>
          <div class="overflow-hidden border border-stone-200 bg-white">
            <img class="h-full w-full object-cover" src={city.heroImage} alt={city.heroAlt} loading={idx === 0 ? 'eager' : 'lazy'} />
          </div>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {city.explore.map((spot) => (
            <article class="border border-stone-200 bg-white p-6">
              <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">我们会体验</p>
              <h3 class="mt-3 text-2xl font-semibold text-stone-900">{spot.titleZh}</h3>
              <p class="mt-3 leading-7 text-stone-600">{spot.descriptionZh}</p>
            </article>
          ))}
        </div>

        <article class="mt-5 border border-stone-200 bg-white p-6 md:p-8">
          <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">食物高光</p>
          <h3 class="mt-3 text-2xl font-semibold text-stone-900">{city.foodHighlight.titleZh}</h3>
          <p class="mt-3 max-w-4xl leading-7 text-stone-600">{city.foodHighlight.descriptionZh}</p>
        </article>

        <div class="mt-5 grid grid-cols-2 gap-4 lg:grid-cols-4">
          {city.gallery.map((image, imageIdx) => (
            <figure class="overflow-hidden border border-stone-200 bg-white">
              <img class="h-52 w-full object-cover md:h-60" src={image} alt={`${city.cityZh} 参考图片 ${imageIdx + 1}`} loading={idx === 0 && imageIdx < 2 ? 'eager' : 'lazy'} />
            </figure>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="py-20 bg-stone-100">
    <div class="container">
      <p class="section-eyebrow">包含内容</p>
      <h2 class="section-title">报名节奏、包含项与不包含项</h2>

      <div class="mt-10 grid gap-5 xl:grid-cols-3">
        <article class="border border-stone-200 bg-white p-6">
          <h3 class="text-2xl font-semibold text-stone-900">订金</h3>
          <p class="mt-3 leading-7 text-stone-600">完成初步沟通与匹配确认后，以 CAD $300 锁定名额。</p>
        </article>
        <article class="border border-stone-200 bg-white p-6">
          <h3 class="text-2xl font-semibold text-stone-900">尾款</h3>
          <p class="mt-3 leading-7 text-stone-600">默认在出发前 30 天完成尾款支付，若确认包有调整则以正式通知为准。</p>
        </article>
        <article class="border border-stone-200 bg-white p-6">
          <h3 class="text-2xl font-semibold text-stone-900">退改</h3>
          <p class="mt-3 leading-7 text-stone-600">完整退改说明会在正式报名确认包中发出，方便你在支付全款前先看清楚。</p>
        </article>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <article class="border border-stone-200 bg-white p-6 md:p-8">
          <p class="section-eyebrow mb-3">包含内容</p>
          <ul class="space-y-3 pl-5 text-stone-700">
            {includedZh.map((item) => <li class="leading-7">{item}</li>)}
          </ul>
        </article>
        <article class="border border-stone-200 bg-white p-6 md:p-8">
          <p class="section-eyebrow mb-3">不包含内容</p>
          <ul class="space-y-3 pl-5 text-stone-700">
            {notIncludedZh.map((item) => <li class="leading-7">{item}</li>)}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container">
      <p class="section-eyebrow">视频参考</p>
      <h2 class="section-title">出发前可以先看看</h2>
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {recommendedVideos.map((video) => (
          <article class="border border-stone-200 bg-[var(--color-bg)] p-6">
            <p class="text-xs uppercase tracking-[0.24em] text-[var(--color-red)]">观看</p>
            <h3 class="mt-3 text-2xl font-semibold text-stone-900">{video.titleZh}</h3>
            <p class="mt-2 text-sm text-stone-500">{video.creator}</p>
            <p class="mt-4 leading-7 text-stone-600">{video.noteZh}</p>
            <a class="mt-5 inline-block font-semibold text-[var(--color-red)] hover:text-[var(--color-red-dark)]" href={video.url} target="_blank">打开视频 ↗</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="faq">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow">常见问题</p>
        <h2 class="section-title">报名前须知</h2>
      </div>
      <div class="faq__list">
        {faqZh.map((f, i) => (
          <div class="faq__item" id={`trip-faq-${i}`}>
            <button class="faq__q" aria-expanded="false" aria-controls={`trip-faq-answer-${i}`}>
              <span>{f.q}</span>
              <svg class="faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="faq__a" id={`trip-faq-answer-${i}`} role="region" aria-labelledby={`trip-faq-${i}`}>
              <div class="faq__a-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="register" class="py-20 bg-stone-900 text-white">
    <div class="container max-w-4xl">
      <p class="section-eyebrow text-red-300">报名</p>
      <h2 class="section-title text-white">提交报名</h2>
      <p class="mx-auto max-w-3xl text-center leading-8 text-stone-300">
        告诉我们你是谁、为什么想来，以及怎么联系你。我们会人工阅读每一份报名，而不是把它当成即时下单流程。
      </p>
      <form class="mt-10 grid gap-4 md:grid-cols-2" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
        <input type="hidden" name="_subject" value="新的探索中国报名线索" />
        <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/zh/success" />
        <input type="hidden" name="_captcha" value="false" />
        <div>
          <label for="name" class="mb-2 block text-sm font-medium text-stone-200">姓名</label>
          <input id="name" name="name" required class="w-full border border-stone-700 bg-stone-950 px-4 py-3 text-white" />
        </div>
        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-stone-200">邮箱</label>
          <input id="email" type="email" name="email" required class="w-full border border-stone-700 bg-stone-950 px-4 py-3 text-white" />
        </div>
        <div>
          <label for="phone" class="mb-2 block text-sm font-medium text-stone-200">微信 / 电话（可选）</label>
          <input id="phone" name="phone" class="w-full border border-stone-700 bg-stone-950 px-4 py-3 text-white" />
        </div>
        <div>
          <label for="city" class="mb-2 block text-sm font-medium text-stone-200">所在城市</label>
          <input id="city" name="city" class="w-full border border-stone-700 bg-stone-950 px-4 py-3 text-white" />
        </div>
        <div class="md:col-span-2">
          <label for="goal" class="mb-2 block text-sm font-medium text-stone-200">你为什么想参加这次行程？</label>
          <textarea id="goal" name="goal" required class="min-h-[140px] w-full border border-stone-700 bg-stone-950 px-4 py-3 text-white"></textarea>
        </div>
        <div class="md:col-span-2 flex justify-center pt-2">
          <button class="bg-red-700 px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-red-800" type="submit">提交报名</button>
        </div>
      </form>
      <p class="mt-5 text-center text-sm text-stone-400">有问题？请发邮件至 {site.email}</p>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.faq__q').forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.faq__q').forEach((b) => b.setAttribute('aria-expanded', 'false'));
        if (!expanded) btn.setAttribute('aria-expanded', 'true');
      });
    });
  </script>
</Layout>
