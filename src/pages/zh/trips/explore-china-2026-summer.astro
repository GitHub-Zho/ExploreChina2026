---
import Layout from '../../../layouts/Layout.astro';
import {
  currentTrip,
  faqZh,
  includedZh,
  notIncludedZh,
  cityGuides,
  itinerary,
  recommendedVideos,
  site,
} from '../../../data/site';
---
<Layout title={currentTrip.titleZh} lang="zh" alternateHref="/trips/explore-china-2026-summer" alternateLabel="EN" darkNav={true}>

  <!-- Hero Banner -->
  <div class="trip-hero">
    <img
      src="https://images.unsplash.com/photo-1508804185872-d7badad00f7d?auto=format&fit=crop&w=1600&q=80"
      alt="北京故宫鸟瞰"
      class="trip-hero__img"
    />
    <div class="trip-hero__overlay">
      <h1 class="trip-hero__title">{currentTrip.titleZh}</h1>
      <p class="trip-hero__sub">{currentTrip.summaryZh}</p>
    </div>
  </div>

  <!-- Overview -->
  <section id="overview" class="section card tone-sand trip-overview" style="padding:34px;">
    <div class="grid cols-4 trip-overview__stats" style="margin-top:14px;">
      <article class="card trip-overview__stat"><p class="label trip-overview__label">路线</p><p class="trip-overview__value">{currentTrip.subtitleZh}</p></article>
      <article class="card trip-overview__stat"><p class="label trip-overview__label">出发时间</p><p class="trip-overview__value">{currentTrip.departureWindowZh}</p></article>
      <article class="card trip-overview__stat"><p class="label trip-overview__label">报名截止</p><p class="trip-overview__value">{currentTrip.applicationDeadlineZh}</p></article>
      <article class="card trip-overview__stat"><p class="label trip-overview__label">团队规模</p><p class="trip-overview__value">{currentTrip.groupSizeZh}</p></article>
    </div>

    <div class="grid cols-2 trip-overview__details" style="margin-top:18px;">
      <article class="card trip-price-card">
        <p class="label trip-price-card__eyebrow">价格</p>
        <p class="trip-price-card__value">{currentTrip.priceCadZh}</p>
        <p class="trip-price-card__note">它更像一条小规模、高支持度的学生旅行路线，而不是标准化的大团产品。</p>
      </article>
      <article class="card trip-overview__fit-card">
        <p class="label trip-overview__label">适合谁</p>
        <p class="trip-overview__body">适合希望行程清晰、有代表性城市、又不想只有“打卡感”的学生与年轻旅行者。</p>
      </article>
    </div>

    <p class="muted trip-overview__contact">联系邮箱：{site.email}</p>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:16px; justify-content:center;">
      <a class="btn btn-primary" href="#register">立即报名</a>
      <a class="btn btn-secondary" href="/zh/handbook">查看参与者手册</a>
    </div>
  </section>

  <!-- Itinerary -->
  <section id="itinerary" class="section card tone-dark">
    <h2 class="section-title">10天路线一览</h2>
    <div class="grid cols-2 trip-route-grid">
      {itinerary.map((d) => (
        <article class="card trip-route-card">
          <p class="pill trip-route-card__day">{d.dayZh}</p>
          <h3 class="trip-route-card__title">{d.cityZh} · {d.titleZh}</h3>
          <p class="muted trip-route-card__plan">{d.planZh}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- City Guides -->
  <section class="section card tone-blue city-tabs-section" id="city-guides" data-city-tabs>
    <div class="city-tabs-section__header">
      <p class="section-eyebrow">城市导览 Tabs</p>
      <h2 class="section-title">先在页面里认识这几座城市</h2>
      <p class="section-sub">点击标签即可原地切换内容，用更有人味的故事、感受和几个关键亮点，提前建立对每一站的熟悉感。</p>
    </div>

    <div class="city-tabs__nav" role="tablist" aria-label="城市导览标签">
      {cityGuides.map((city, idx) => (
        <button
          type="button"
          class={`city-tabs__tab ${idx === 0 ? 'is-active' : ''}`}
          id={`city-tab-${city.city.toLowerCase()}`}
          role="tab"
          aria-selected={idx === 0 ? 'true' : 'false'}
          aria-controls={`city-panel-${city.city.toLowerCase()}`}
          data-city-tab={city.city.toLowerCase()}
          tabindex={idx === 0 ? '0' : '-1'}
        >
          <span>{city.cityZh}</span>
          <span class="city-tabs__tab-sub">{city.city}</span>
        </button>
      ))}
    </div>

    {cityGuides.map((city, idx) => (
      <article
        class={`city-tabs__panel ${idx === 0 ? 'is-active' : ''}`}
        id={`city-panel-${city.city.toLowerCase()}`}
        role="tabpanel"
        aria-labelledby={`city-tab-${city.city.toLowerCase()}`}
        hidden={idx !== 0}
        data-city-panel={city.city.toLowerCase()}
      >
        <div class="city-tabs__panel-grid">
          <figure class="card city-tabs__hero">
            <img class="photo media-wide" src={city.heroImage} alt={city.heroAlt} loading={idx === 0 ? 'eager' : 'lazy'} />
          </figure>
          <div class="city-tabs__story">
            <p class="pill">{city.cityZh} · {city.city}</p>
            <h3 class="city-tabs__title">为什么这座城市值得你在路上认真感受</h3>
            <p class="city-tabs__lead">{city.contextZh}</p>
            <p class="city-tabs__text">{city.feelingZh}</p>
          </div>
        </div>

        <div class="city-tabs__highlights">
          {city.explore.slice(0, 4).map((spot) => (
            <article class="card city-tabs__highlight">
              <p class="label">关键亮点</p>
              <h4>{spot.titleZh}</h4>
              <p class="muted">{spot.descriptionZh}</p>
            </article>
          ))}
        </div>
      </article>
    ))}
  </section>

  <!-- Included / Not Included -->
  <section class="section grid cols-2">
    <article class="card"><h2 style="font-size:30px;">包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{includedZh.map((item) => <li>{item}</li>)}</ul></article>
    <article class="card"><h2 style="font-size:30px;">不包含内容</h2><ul class="muted" style="line-height:1.8; padding-left:18px; margin:0;">{notIncludedZh.map((item) => <li>{item}</li>)}</ul></article>
  </section>

  <!-- Videos -->
  <section class="section card tone-blue">
    <h2 class="section-title">出发前可以先看的视频</h2>
    <div class="grid cols-3">
      {recommendedVideos.map((video) => (
        <article class="card" style="background:#fff;">
          <p class="label">视频参考</p>
          <h3 style="margin:8px 0 6px;">{video.titleZh}</h3>
          <p class="muted" style="margin:0 0 10px;">{video.creator}</p>
          <p class="muted" style="margin:0 0 12px; line-height:1.8;">{video.noteZh}</p>
          <a class="text-link" href={video.url} target="_blank">打开视频 ↗</a>
        </article>
      ))}
    </div>
  </section>

  <!-- FAQ (accordion, consistent with homepage) -->
  <section id="faq" class="faq">
    <div class="container">
      <div class="section-header">
        <p class="section-eyebrow">常见问题</p>
        <h2 class="section-title">常见问题解答</h2>
      </div>
      <div class="faq__list">
        {faqZh.map((f, i) => (
          <div class="faq__item" id={`trip-faq-${i}`}>
            <button class="faq__q" aria-expanded="false" aria-controls={`trip-faq-answer-${i}`}>
              <span>{f.q}</span>
              <svg class="faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="faq__a" id={`trip-faq-answer-${i}`} role="region" aria-labelledby={`trip-faq-${i}`}>
              <div class="faq__a-inner">{f.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Apply -->
  <section id="register" class="section card tone-dark" style="margin-bottom:36px;">
    <h2 class="section-title">报名</h2>
    <p class="muted" style="text-align:center; max-width:760px; margin:0 auto 20px;">告诉我们你是谁、为什么想来，以及怎么联系你。我们会人工阅读每一份报名，而不是把它当成即时下单流程。</p>
    <form class="form-grid" action="https://formsubmit.co/jo_oyoy@outlook.com" method="POST">
      <input type="hidden" name="_subject" value="新的探索中国报名线索" />
      <input type="hidden" name="_next" value="https://explore-china-site.vercel.app/zh/success" />
      <input type="hidden" name="_captcha" value="false" />
      <div class="field"><label for="name">姓名</label><input id="name" name="name" required /></div>
      <div class="field"><label for="email">邮箱</label><input id="email" type="email" name="email" required /></div>
      <div class="field"><label for="phone">微信 / 电话（可选）</label><input id="phone" name="phone" /></div>
      <div class="field"><label for="city">所在城市</label><input id="city" name="city" /></div>
      <div class="field" style="grid-column:1 / -1;"><label for="goal">你为什么想参加这次行程？</label><textarea id="goal" name="goal" required></textarea></div>
      <div style="grid-column:1 / -1; display:flex; gap:10px; justify-content:center;"><button class="btn btn-primary" type="submit">提交报名</button></div>
    </form>
    <p class="muted" style="text-align:center; margin-top:10px;">有问题？请发邮件至 {site.email}</p>
  </section>
</Layout>

<style>
.trip-hero {
  position: relative;
  height: 420px;
  overflow: hidden;
}
.trip-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.trip-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.55) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 2.5rem;
  text-align: center;
}
.trip-hero__title {
  color: #fff;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  font-family: var(--font-display);
  line-height: 1.1;
  margin-bottom: 0.75rem;
}
.trip-hero__sub {
  color: rgba(255,255,255,0.85);
  font-size: 1.1rem;
  max-width: 640px;
  line-height: 1.7;
}
</style>

<script is:inline>
  document.querySelectorAll('.faq__q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq__q').forEach((b) => b.setAttribute('aria-expanded', 'false'));
      if (!expanded) btn.setAttribute('aria-expanded', 'true');
    });
  });

  document.querySelectorAll('[data-city-tabs]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll('[data-city-tab]'));
    const panels = Array.from(root.querySelectorAll('[data-city-panel]'));

    const activateTab = (key) => {
      tabs.forEach((tab) => {
        const active = tab.getAttribute('data-city-tab') === key;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
        tab.setAttribute('tabindex', active ? '0' : '-1');
      });

      panels.forEach((panel) => {
        const active = panel.getAttribute('data-city-panel') === key;
        panel.classList.toggle('is-active', active);
        panel.hidden = !active;
      });
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => activateTab(tab.getAttribute('data-city-tab')));
      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        event.preventDefault();
        const nextIndex = event.key === 'ArrowRight'
          ? (index + 1) % tabs.length
          : (index - 1 + tabs.length) % tabs.length;
        const nextTab = tabs[nextIndex];
        nextTab.focus();
        activateTab(nextTab.getAttribute('data-city-tab'));
      });
    });
  });
</script>
