---
import Layout from '../../layouts/Layout.astro';
import { handbookSections, handbookPrep, site } from '../../data/site';
---
<Layout title="探索中国手册" lang="zh" alternateHref="/handbook" alternateLabel="EN" minimalNav={true} darkNav={true}>
  <section id="guide" class="section card tone-sand" style="padding:34px;">
    <p class="pill">参与者手册</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:10px;">探索中国手册</h1>
    <p class="muted" style="max-width:860px; font-size:18px;">出发前实用指南：住宿安排、后勤准备、文化适应与现场预期说明。</p>
  </section>

  <section id="overview" class="section card tone-blue">
    <h2 class="section-title">项目定位</h2>
    <p class="muted" style="max-width:920px; line-height:1.9;">{handbookSections.introZh}</p>
    <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn btn-secondary" href="/zh/trips/explore-china-2026-summer">查看完整行程页 →</a>
      <a class="btn btn-primary" href="/zh/trips/explore-china-2026-summer#register">前往报名</a>
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card tone-rose">
      <h2>住宿安排</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.accommodationZh}</p>
    </article>
    <article class="card tone-rose">
      <h2>饮食需求</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.dietaryZh}</p>
    </article>
    <article class="card tone-blue">
      <h2>语言支持</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.languageZh}</p>
    </article>
    <article class="card tone-blue">
      <h2>安全与协调</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.safetyZh}</p>
    </article>
  </section>

  <section class="section card tone-sand" style="margin-bottom:36px;">
    <h2 class="section-title">出发前 checklist</h2>
    <div class="grid cols-2">
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.beforeYouLeave.titleZh}</h3>
        <p class="muted">{handbookPrep.beforeYouLeave.textZh}</p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.visa.titleZh}</h3>
        <p class="muted">{handbookPrep.visa.textZh}</p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.payment.titleZh}</h3>
        <p class="muted">{handbookPrep.payment.textZh}</p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.sim.titleZh}</h3>
        <p class="muted">{handbookPrep.sim.textZh}</p>
      </article>
      <article class="card" style="background:#fff; grid-column:1 / -1;">
        <h3>{handbookPrep.packList.titleZh}</h3>
        <ul class="muted" style="line-height:1.8; padding-left:18px; margin:8px 0 0;">
          {handbookPrep.packList.itemsZh.map((item) => <li>{item}</li>)}
        </ul>
        <p style="margin-top:10px;"><a class="text-link" href="https://www.travelchina.org.cn/en" target="_blank">中国旅行官方资源 ↗</a></p>
        <p><a class="text-link" href="https://www.china-briefing.com/news/china-visa-free-policies-complete-guide/" target="_blank">中国免签政策说明 ↗</a></p>
      </article>
    </div>
    <p class="muted" style="margin-top:16px;">如果出发前还有问题，请发邮件至 {site.email}，我们会把你导向对应的准备步骤。</p>
  </section>
</Layout>
