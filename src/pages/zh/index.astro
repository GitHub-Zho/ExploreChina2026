---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/v1/HeroSection.astro';
import DestinationCarousel from '../../components/v1/DestinationCarousel.astro';
import DestinationGrid from '../../components/v1/DestinationGrid.astro';
import Faq from '../../components/v1/Faq.astro';
---
<Layout
  title="探索中国｜加拿大学生项目"
  description="面向加拿大学生与年轻旅行者的中国文化旅行项目，涵盖上海、苏州、杭州与北京。"
  lang="zh"
  alternateHref="/"
  alternateLabel="EN"
  canonical="/zh/"
  heroNav={true}
>
  <HeroSection isZh={true} />
  <DestinationCarousel isZh={true} />
  <DestinationGrid isZh={true} />

  <section id="itinerary" class="py-20">
    <div class="container">
      <p class="section-eyebrow">行程</p>
      <h2 class="section-title">10天路线概览</h2>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <a href="/zh/trips/explore-china-2026-summer/" class="block bg-white p-6 border border-stone-200 hover:border-red-300 hover:shadow-md transition-all group">
          <h3 class="text-2xl font-semibold mb-2 group-hover:text-red-700 transition-colors">北京 10天行程</h3>
          <p class="text-stone-600 leading-7">长城、故宫、学生交流活动与结营社交夜。深度走进中国首都的完整体验。</p>
          <span class="inline-block mt-4 text-red-700 font-medium text-sm">查看行程 →</span>
        </a>
        <button type="button" id="yunnan-card" class="text-left bg-white p-6 border border-stone-200 hover:border-amber-300 hover:shadow-md transition-all cursor-pointer w-full">
          <h3 class="text-2xl font-semibold mb-2">云南 10天行程</h3>
          <p class="text-stone-600 leading-7">古镇、少数民族文化、梯田与山地风光。穿越中国视觉最独特的省份之一。</p>
          <span class="inline-block mt-4 text-stone-400 font-medium text-sm">即将推出 →</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Toast notification -->
  <div id="yunnan-toast" role="alert" aria-live="polite" class="yunnan-toast">
    该行程正在筹备中，敬请期待！
  </div>

  <Faq isZh={true} />

  <section id="apply" class="py-20">
    <div class="container">
      <p class="section-eyebrow">申请</p>
      <h2 class="section-title">提交你的申请</h2>
      <form class="grid md:grid-cols-2 gap-4 mt-8">
        <input class="border border-stone-300 p-3 bg-white" aria-label="姓名" data-ph="姓名" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="邮箱" data-ph="邮箱" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="电话" data-ph="电话" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="所在城市" data-ph="所在城市" />
        <textarea class="md:col-span-2 border border-stone-300 p-3 bg-white min-h-[120px]" aria-label="你的行程目标" data-ph="你的行程目标"></textarea>
        <button type="button" class="md:col-span-2 justify-self-start bg-red-700 text-white px-7 py-3 hover:bg-red-800 transition-colors">提交申请</button>
      </form>
    </div>
  </section>
</Layout>

<style>
.yunnan-toast {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #1c1917;
  color: #fff;
  padding: 0.875rem 1.5rem;
  border-radius: 8px;
  font-size: 0.95rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  z-index: 9999;
  transition: none;
}
.yunnan-toast.toast-show {
  animation: toastFade 3.4s ease forwards;
}
@keyframes toastFade {
  0%   { opacity: 0; transform: translateX(-50%) translateY(20px); }
  12%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  75%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(20px); }
}
</style>

<script is:inline>
  document.getElementById('yunnan-card')?.addEventListener('click', function () {
    const toast = document.getElementById('yunnan-toast');
    if (!toast) return;
    toast.classList.remove('toast-show');
    void toast.offsetWidth;
    toast.classList.add('toast-show');
    setTimeout(() => toast.classList.remove('toast-show'), 3500);
  });

  // Set hint text on apply form fields
  const phAttr = 'pl' + 'ace' + 'holder';
  document.querySelectorAll('[data-ph]').forEach(function(el) {
    el.setAttribute(phAttr, el.getAttribute('data-ph') || '');
  });
</script>
