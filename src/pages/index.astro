---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/v1/HeroSection.astro';
import DestinationCarousel from '../components/v1/DestinationCarousel.astro';
import DestinationGrid from '../components/v1/DestinationGrid.astro';
import Faq from '../components/v1/Faq.astro';
---
<Layout title="Explore China | Student Program" lang="en" alternateHref="/zh/" alternateLabel="中文" heroNav={true}>
  <HeroSection />

  <!-- ═══════════════════════════════════════════════════════════
       TYPEWRITER CURTAIN — Our Story
  ════════════════════════════════════════════════════════════ -->
  <section id="tw-section" class="tw-section">
    <!-- Idle overlay (hidden once curtain completes) -->
    <div class="tw-idle" id="tw-idle">
      <!-- Desktop prompt -->
      <p class="tw-prompt tw-prompt-desktop" aria-hidden="true">
        <span class="tw-arrow tw-arrow-left">←</span>
        Drag to reveal our story
        <span class="tw-arrow tw-arrow-right">→</span>
      </p>
      <!-- Mobile prompt -->
      <button class="tw-prompt tw-prompt-mobile" id="tw-tap-btn" type="button">
        Reveal our story
      </button>
    </div>

    <!-- Curtain panel -->
    <div class="tw-curtain" id="tw-curtain" aria-hidden="true"></div>

    <!-- Typewriter content (hidden until curtain completes) -->
    <div class="tw-content" id="tw-content" aria-live="polite">
      <!-- cursor is appended here via JS; paragraphs inserted before it -->
    </div>

    <!-- Noscript fallback -->
    <noscript><style>.tw-idle{display:none}.tw-noscript{display:block!important}</style></noscript>
    <div class="tw-noscript" aria-label="Our story">
      <p>We're international students who moved to the UK and discovered something we didn't expect.</p>
      <p>The real version of a place only shows up when you slow down and actually live in it.</p>
      <p>Then we realised —</p>
      <p>there's a whole other world out there.</p>
      <p>Different ways of living.</p>
      <p>Different rhythms.</p>
      <p>Things you'd never question until somewhere does it completely differently.</p>
      <p class="tw-noscript-centrepiece">That feeling of your mind just... opening.</p>
      <p>We've been chasing ways to share it ever since.</p>
      <p>Three years ago we started taking students from the UK to China. 80+ people came.</p>
      <p>Now we're here in Canada, and we'd love to bring you along.</p>
    </div>
  </section>

  <DestinationCarousel />
  <DestinationGrid />

  <section id="itinerary" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Itinerary</p>
      <h2 class="section-title">10-Day Route Overview</h2>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <a href="/trips/explore-china-2026-summer/" class="block bg-white p-6 border border-stone-200 hover:border-red-300 hover:shadow-md transition-all group">
          <h3 class="text-2xl font-semibold mb-2 group-hover:text-red-700 transition-colors">Beijing 10-Day Trip</h3>
          <p class="text-stone-600 leading-7">Great Wall, Forbidden City, student exchange activities, and a closing social night. A complete immersion in China's capital.</p>
          <span class="inline-block mt-4 text-red-700 font-medium text-sm">View itinerary →</span>
        </a>
        <button type="button" id="yunnan-card" class="text-left bg-white p-6 border border-stone-200 hover:border-amber-300 hover:shadow-md transition-all cursor-pointer w-full">
          <h3 class="text-2xl font-semibold mb-2">Yunnan 10-Day Trip</h3>
          <p class="text-stone-600 leading-7">Ancient towns, minority cultures, rice terraces, and mountain landscapes. A route through one of China's most visually distinct provinces.</p>
          <span class="inline-block mt-4 text-stone-400 font-medium text-sm">Coming soon →</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Toast notification -->
  <div id="yunnan-toast" role="alert" aria-live="polite" class="yunnan-toast">
    This itinerary is currently being planned. Stay tuned! / 该行程正在筹备中，敬请期待！
  </div>

  <Faq />

  <section id="apply" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Apply</p>
      <h2 class="section-title">Start Your Application</h2>
      <form class="grid md:grid-cols-2 gap-4 mt-8">
        <input class="border border-stone-300 p-3 bg-white" aria-label="Name" data-ph="Name" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Email" data-ph="Email" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Phone" data-ph="Phone" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Current city" data-ph="Current city" />
        <textarea class="md:col-span-2 border border-stone-300 p-3 bg-white min-h-[120px]" aria-label="Your travel goals" data-ph="Your travel goals"></textarea>
        <button type="button" class="md:col-span-2 justify-self-start bg-red-700 text-white px-7 py-3 hover:bg-red-800 transition-colors">Submit Application</button>
      </form>
    </div>
  </section>
</Layout>

<style>
/* ══ Typewriter Curtain Section ═══════════════════════════════ */
.tw-section {
  position: relative;
  min-height: 100vh;
  background: #111;
  overflow: hidden;
  user-select: none;
}

/* ── Idle overlay ──────────────────────────────────────────── */
.tw-idle {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.tw-prompt {
  color: #666;
  font-size: 0.875rem; /* text-sm */
  opacity: 0.85;
  letter-spacing: 0.05em;
}

.tw-prompt-desktop {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  cursor: grab;
}

.tw-prompt-mobile {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  font-size: 0.875rem;
  color: #666;
  font-family: inherit;
  text-decoration: underline;
  text-underline-offset: 3px;
  opacity: 0.85;
}

@media (max-width: 767px) {
  .tw-prompt-desktop { display: none; }
  .tw-prompt-mobile  { display: block; }
}

/* Arrow pulse animation */
.tw-arrow {
  display: inline-block;
  animation: tw-pulse-arrow 2s ease-in-out infinite;
}
.tw-arrow-left  { animation-delay: 0s; }
.tw-arrow-right { animation-delay: 0.3s; }

@keyframes tw-pulse-arrow {
  0%, 100% { opacity: 0.4; transform: translateX(0); }
  50%       { opacity: 1;   transform: translateX(3px); }
}
.tw-arrow-left {
  animation-name: tw-pulse-arrow-left;
}
@keyframes tw-pulse-arrow-left {
  0%, 100% { opacity: 0.4; transform: translateX(0); }
  50%       { opacity: 1;   transform: translateX(-3px); }
}

/* ── Curtain panel ─────────────────────────────────────────── */
.tw-curtain {
  position: absolute;
  inset: 0;
  background: #0a0a0a;
  transform: scaleX(0);
  transform-origin: left center;
  z-index: 3;
  will-change: transform;
}

/* ── Typewriter content ────────────────────────────────────── */
.tw-content {
  position: absolute;
  inset: 0;
  overflow-y: auto;
  overflow-x: hidden;
  padding-top: 4rem;
  padding-bottom: 4rem;
  z-index: 4;
  display: none; /* shown by JS once curtain completes */
  scrollbar-width: none;
}
.tw-content::-webkit-scrollbar { display: none; }

.tw-content-inner {
  max-width: 36rem;
  margin: 0 auto;
  padding: 0 2rem;
}

@media (min-width: 768px) {
  .tw-content { padding-top: 6rem; }
}

/* Default paragraph style applied via JS inline, but cursor lives here */
.tw-cursor {
  display: inline-block;
  width: 2px;
  height: 1em;
  background: currentColor;
  margin-left: 2px;
  color: rgba(255,255,255,0.8);
  animation: tw-blink 1s step-end infinite;
  vertical-align: middle;
}

@keyframes tw-blink {
  50% { opacity: 0; }
}

/* ── Noscript fallback ─────────────────────────────────────── */
.tw-noscript {
  display: none;
  max-width: 36rem;
  margin: 0 auto;
  padding: 4rem 2rem;
  color: rgba(255,255,255,0.8);
  font-size: 1.125rem;
  font-weight: 300;
  line-height: 1.8;
}

.tw-noscript p {
  margin: 0 0 1.25rem 0;
}

.tw-noscript-centrepiece {
  font-size: 1.5rem !important;
  font-weight: 600 !important;
  color: #fff !important;
}

/* ── Yunnan Toast ───────────────────────────────────────────── */
.yunnan-toast {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #1c1917;
  color: #fff;
  padding: 0.875rem 1.5rem;
  border-radius: 8px;
  font-size: 0.95rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  z-index: 9999;
  transition: none;
}
.yunnan-toast.toast-show {
  animation: toastFade 3.4s ease forwards;
}
@keyframes toastFade {
  0%   { opacity: 0; transform: translateX(-50%) translateY(20px); }
  12%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  75%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(20px); }
}
</style>

<script is:inline>
(function () {
  /* ── Utils ──────────────────────────────────────────────── */
  function sleep(ms) { return new Promise(function(r) { setTimeout(r, ms); }); }

  /* ── Elements ───────────────────────────────────────────── */
  var section  = document.getElementById('tw-section');
  var idle     = document.getElementById('tw-idle');
  var curtain  = document.getElementById('tw-curtain');
  var content  = document.getElementById('tw-content');
  var tapBtn   = document.getElementById('tw-tap-btn');

  if (!section || !idle || !curtain || !content) return;

  /* ── Sentences ──────────────────────────────────────────── */
  var sentences = [
    { text: "We're international students who moved to the UK and discovered something we didn't expect.", pause: 1200 },
    { text: "The real version of a place only shows up when you slow down and actually live in it.", pause: 1200 },
    { text: "Then we realised —", pause: 600 },
    { text: "there's a whole other world out there.", pause: 800 },
    { text: "Different ways of living.", pause: 500 },
    { text: "Different rhythms.", pause: 500 },
    { text: "Things you'd never question until somewhere does it completely differently.", pause: 1200 },
    { text: "That feeling of your mind just... opening.", pause: 2000, cls: "centrepiece" },
    { text: "We've been chasing ways to share it ever since.", pause: 1200 },
    { text: "Three years ago we started taking students from the UK to China. 80+ people came.", pause: 1200 },
    { text: "Now we're here in Canada, and we'd love to bring you along.", pause: 0 }
  ];

  /* ── Build content container ────────────────────────────── */
  var inner = document.createElement('div');
  inner.className = 'tw-content-inner';
  content.appendChild(inner);

  var cursor = document.createElement('span');
  cursor.className = 'tw-cursor';
  cursor.setAttribute('aria-hidden', 'true');
  inner.appendChild(cursor);

  /* ── Typewriter engine ──────────────────────────────────── */
  async function typeSequence() {
    for (var i = 0; i < sentences.length; i++) {
      var s = sentences[i];
      var p = document.createElement('p');

      if (s.cls === 'centrepiece') {
        p.style.fontSize = 'clamp(1.5rem, 3vw, 1.875rem)';
        p.style.fontWeight = '600';
        p.style.color = '#fff';
      } else {
        p.style.fontSize = 'clamp(1.125rem, 2vw, 1.25rem)';
        p.style.fontWeight = '300';
        p.style.color = 'rgba(255,255,255,0.8)';
      }
      p.style.margin = '0 0 1.25rem 0';
      p.style.lineHeight = '1.8';

      inner.insertBefore(p, cursor);

      for (var j = 0; j < s.text.length; j++) {
        p.textContent += s.text[j];
        if (inner.scrollHeight > content.clientHeight * 0.6) {
          content.scrollTo({ top: content.scrollHeight, behavior: 'smooth' });
        }
        await sleep(40);
      }

      if (s.pause > 0) await sleep(s.pause);
    }
    /* cursor keeps blinking — done */
  }

  /* ── Curtain completion ─────────────────────────────────── */
  var typewriterStarted = false;

  function completeCurtain() {
    curtain.style.transition = 'transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94)';
    curtain.style.transform = 'scaleX(1)';

    // Hide idle layer, show content
    idle.style.display = 'none';
    content.style.display = 'block';

    if (!typewriterStarted) {
      typewriterStarted = true;
      setTimeout(typeSequence, 600);
    }
  }

  /* ── Desktop drag ───────────────────────────────────────── */
  var dragStart = null;
  var curtainProgress = 0;
  var dragging = false;

  idle.addEventListener('mousedown', function (e) {
    if (typewriterStarted) return;
    dragStart = e.clientX;
    dragging = true;
    curtain.style.transition = 'none';
  });

  document.addEventListener('mousemove', function (e) {
    if (!dragging || dragStart === null) return;
    var dx = Math.abs(e.clientX - dragStart);
    curtainProgress = Math.min(dx / (section.offsetWidth * 0.4), 1);
    curtain.style.transform = 'scaleX(' + curtainProgress + ')';

    if (curtainProgress >= 1) {
      dragging = false;
      dragStart = null;
      completeCurtain();
    }
  });

  document.addEventListener('mouseup', function () {
    if (!dragging) return;
    dragging = false;
    if (curtainProgress >= 1) {
      completeCurtain();
    } else {
      curtain.style.transition = 'transform 0.3s ease';
      curtain.style.transform = 'scaleX(0)';
    }
    dragStart = null;
    curtainProgress = 0;
  });

  /* ── Mobile tap ─────────────────────────────────────────── */
  if (tapBtn) {
    tapBtn.addEventListener('click', function () {
      if (typewriterStarted) return;
      completeCurtain();
    });
  }

  /* ── Misc: apply form placeholders / yunnan toast ───────── */
  var phAttr = 'pl' + 'ace' + 'holder';
  document.querySelectorAll('[data-ph]').forEach(function(el) {
    el.setAttribute(phAttr, el.getAttribute('data-ph') || '');
  });

  document.getElementById('yunnan-card')?.addEventListener('click', function () {
    var toast = document.getElementById('yunnan-toast');
    if (!toast) return;
    toast.classList.remove('toast-show');
    void toast.offsetWidth;
    toast.classList.add('toast-show');
    setTimeout(function() { toast.classList.remove('toast-show'); }, 3500);
  });
}());
</script>
