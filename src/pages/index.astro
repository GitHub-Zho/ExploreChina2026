---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/v1/HeroSection.astro';
import DestinationCarousel from '../components/v1/DestinationCarousel.astro';
import DestinationGrid from '../components/v1/DestinationGrid.astro';
import Faq from '../components/v1/Faq.astro';
---
<Layout title="Explore China | Student Program" lang="en" alternateHref="/zh/" alternateLabel="中文" heroNav={true}>
  <HeroSection />

  <!-- ═══════════════════════════════════════════════════════════
       STORY SECTION — Version C look + Curtain + Version B Typewriter
  ════════════════════════════════════════════════════════════ -->
  <section id="story-section" class="story-c-section" aria-label="Our Story">

    <!-- STATE 1: Idle — Version C visual style -->
    <div class="story-c-inner" id="story-idle">
      <p class="story-c-item story-c-context" data-story-c-item>
        We went overseas to study. We thought we'd seen the world.
      </p>
      <p class="story-c-item story-c-hero" data-story-c-item>
        There's a version of the world you can only find by living in it.
      </p>
      <p class="story-c-item story-c-closer" data-story-c-item>
        Now we're in Canada. Your turn.
      </p>
      <div class="story-drag-prompt story-c-item" id="story-drag-prompt" aria-hidden="true" data-story-c-item>
        <div class="story-drag-indicator">
          <div class="story-drag-line"></div>
          <div class="story-drag-circle">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#1c1917" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 10h12"/>
              <path d="M12 6l4 4-4 4"/>
            </svg>
          </div>
          <div class="story-drag-line"></div>
        </div>
        <p class="story-drag-prompt__text">Swipe to reveal</p>
      </div>
    </div>

    <!-- STATE 2: Curtain overlay -->
    <div class="story-curtain" id="story-curtain" aria-hidden="true"></div>

    <!-- STATE 3: Typewriter — centred credits roll -->
    <div class="story-b-section" id="story-typewriter" aria-live="polite">
      <div class="story-b-scroll" id="story-b-scroll">
        <div class="story-b-spacer"></div>
        <div class="story-b-content" id="story-b-content">
          <!-- sentences appended here by JS, cursor moves inline -->
        </div>
        <div class="story-b-spacer"></div>
      </div>
      <!-- Replay — appears inside scroll after text -->
      <div class="story-replay" id="story-replay" role="button" tabindex="0" aria-label="Read again">
        <svg width="36" height="36" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M29 18c0 6-4.9 11-11 11S7 24 7 18 11.9 7 18 7c3.3 0 6.2 1.4 8.2 3.7"/>
          <polyline points="27,5 27,12 20,12"/>
        </svg>
        <p class="story-replay__text">Read again</p>
      </div>
    </div>

    <!-- Noscript fallback: show Version C's 3 lines statically -->
    <noscript>
      <style>.story-c-inner { display: none !important; }</style>
      <div class="story-noscript">
        <p class="story-c-context">We went overseas to study. We thought we'd seen the world.</p>
        <p class="story-c-hero">There's a version of the world you can only find by living in it.</p>
        <p class="story-c-closer">Now we're in Canada. Your turn.</p>
      </div>
    </noscript>
  </section>

  <DestinationCarousel />
  <DestinationGrid />

  <section id="itinerary" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Itinerary</p>
      <h2 class="section-title">10-Day Route Overview</h2>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <a href="/trips/explore-china-2026-summer/" class="block bg-white p-6 border border-stone-200 hover:border-red-300 hover:shadow-md transition-all group">
          <h3 class="text-2xl font-semibold mb-2 group-hover:text-red-700 transition-colors">Beijing 10-Day Trip</h3>
          <p class="text-stone-600 leading-7">Great Wall, Forbidden City, student exchange activities, and a closing social night. A complete immersion in China's capital.</p>
          <span class="inline-block mt-4 text-red-700 font-medium text-sm">View itinerary →</span>
        </a>
        <button type="button" id="yunnan-card" class="text-left bg-white p-6 border border-stone-200 hover:border-amber-300 hover:shadow-md transition-all cursor-pointer w-full">
          <h3 class="text-2xl font-semibold mb-2">Yunnan 10-Day Trip</h3>
          <p class="text-stone-600 leading-7">Ancient towns, minority cultures, rice terraces, and mountain landscapes. A route through one of China's most visually distinct provinces.</p>
          <span class="inline-block mt-4 text-stone-400 font-medium text-sm">Coming soon →</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Toast notification -->
  <div id="yunnan-toast" role="alert" aria-live="polite" class="yunnan-toast">
    This itinerary is currently being planned. Stay tuned! / 该行程正在筹备中，敬请期待！
  </div>

  <Faq />

  <section id="apply" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Apply</p>
      <h2 class="section-title">Start Your Application</h2>
      <form class="grid md:grid-cols-2 gap-4 mt-8">
        <input class="border border-stone-300 p-3 bg-white" aria-label="Name" data-ph="Name" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Email" data-ph="Email" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Phone" data-ph="Phone" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Current city" data-ph="Current city" />
        <textarea class="md:col-span-2 border border-stone-300 p-3 bg-white min-h-[120px]" aria-label="Your travel goals" data-ph="Your travel goals"></textarea>
        <button type="button" class="md:col-span-2 justify-self-start bg-red-700 text-white px-7 py-3 hover:bg-red-800 transition-colors">Submit Application</button>
      </form>
    </div>
  </section>
</Layout>

<style>
/* ══ Story Section: Version C + Curtain + Version B Typewriter ══════════════ */

/* ── Container ─────────────────────────────────────────────── */
.story-c-section {
  position: relative;
  height: 100vh;
  height: 100dvh; /* dynamic viewport — accounts for mobile address bar */
  background: #fdfcfb;
  overflow: hidden;
  user-select: none;
  touch-action: manipulation;
}

/* ── STATE 1: Version C idle ────────────────────────────────── */
.story-c-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  padding: 4rem 2rem;
  text-align: center;
  z-index: 1;
  cursor: grab;
}
.story-c-inner:active { cursor: grabbing; }

.story-c-item {
  margin: 0;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.story-c-item.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.story-c-context {
  font-size: 1rem;
  font-weight: 300;
  color: #78716c;
  line-height: 1.6;
}
@media (min-width: 768px) {
  .story-c-context { font-size: 1.125rem; }
}

.story-c-hero {
  font-size: clamp(1.875rem, 5vw, 3.75rem);
  font-weight: 600;
  color: #1c1917;
  line-height: 1.2;
}

.story-c-closer {
  font-size: 1rem;
  font-weight: 300;
  color: #78716c;
  line-height: 1.6;
}
@media (min-width: 768px) {
  .story-c-closer { font-size: 1.125rem; }
}

/* ── Drag prompt + indicator ─────────────────────────────────── */
.story-drag-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  margin: 1.5rem 0 0;
}
.story-drag-prompt__text {
  font-size: 0.8rem;
  color: #a8a09a;
  font-weight: 300;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0;
}
.story-drag-indicator {
  display: flex;
  align-items: center;
  gap: 0;
}
.story-drag-line {
  width: 48px;
  height: 1px;
  background: #d6d3d1;
}
.story-drag-circle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid #d6d3d1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  animation: dragPulse 2.5s ease-in-out infinite;
  flex-shrink: 0;
}
.story-drag-circle svg {
  animation: dragArrow 2.5s ease-in-out infinite;
}
@keyframes dragPulse {
  0%, 100% { transform: scale(1); border-color: #d6d3d1; }
  50% { transform: scale(1.08); border-color: #a8a09a; }
}
@keyframes dragArrow {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(3px); }
}

/* ── STATE 2: Curtain ───────────────────────────────────────── */
.story-curtain {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #fdfcfb;
  transform: translateX(-100%);
  z-index: 3;
  will-change: transform;
  box-shadow: 6px 0 24px rgba(28, 25, 23, 0.12);
}

/* ── STATE 3: Typewriter — Version B ────────────────────────── */
.story-b-section {
  position: absolute;
  inset: 0;
  background: #fdfcfb;
  display: none; /* set to flex by JS when active */
  align-items: center;
  justify-content: center;
  z-index: 4;
}

/* Credits-roll scroll container — fills entire section */
.story-b-scroll {
  position: absolute;
  inset: 0;
  overflow-y: hidden;
  /* Fade mask: text fades at top AND bottom edges */
  -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 18%, black 82%, transparent 100%);
  mask-image: linear-gradient(to bottom, transparent 0%, black 18%, black 82%, transparent 100%);
}

/* Top spacer pushes first sentence to vertical centre */
.story-b-spacer {
  height: 50vh;
  flex-shrink: 0;
}
.story-b-spacer:first-child {
  /* Offset by half a line height so text sits at true centre */
  height: calc(50vh - 1.5rem);
}

.story-b-content {
  max-width: 34rem;
  margin: 0 auto;
  padding: 0 2rem;
  text-align: center;
  overflow-wrap: break-word;
  word-wrap: break-word;
}

:global(.story-b-content p) {
  margin: 0 0 6rem 0;
  font-size: clamp(1.05rem, 2.2vw, 1.35rem);
  font-weight: 300;
  color: #57534e;
  line-height: 1.45;
}

:global(.story-b-content p.is-centre) {
  font-size: clamp(1.35rem, 3vw, 1.875rem);
  font-weight: 500;
  color: #1c1917;
  margin: 3rem 0 7rem;
  line-height: 1.3;
}

/* Credits-roll: starts hidden, JS drives blur + opacity by position */
:global(.story-line) {
  will-change: filter, opacity;
  filter: blur(8px);
  opacity: 0;
}



/* ── Replay button ──────────────────────────────────────────── */
.story-replay {
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 0;
  cursor: pointer;
  opacity: 0;
  color: #a8a09a;
  transition: opacity 0.6s ease;
  position: absolute;
  bottom: 15%;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
}
.story-replay svg {
  transition: transform 0.6s ease;
}
.story-replay:hover {
  opacity: 0.85 !important;
}
.story-replay:hover svg {
  transform: rotate(360deg);
}
.story-replay__text {
  margin: 0.5rem 0 0;
  font-size: 0.8rem;
  color: #a8a09a;
  letter-spacing: 0.1em;
  font-weight: 300;
}

/* ── Mobile adjustments ─────────────────────────────────────── */
@media (max-width: 767px) {
  .story-c-inner {
    gap: 2rem;
    padding: 3rem 1.5rem;
  }
  .story-c-hero {
    font-size: clamp(1.5rem, 6vw, 2.25rem);
  }
  .story-drag-line { width: 32px; }
  .story-drag-circle { width: 40px; height: 40px; }
  .story-b-text-wrap {
    font-size: clamp(1rem, 4vw, 1.25rem);
    line-height: 1.8;
    padding: 0 0.5rem;
    min-height: 4rem;
  }
}

/* ── Noscript fallback ──────────────────────────────────────── */
.story-noscript {
  display: none;
  max-width: 38rem;
  margin: 0 auto;
  padding: 8rem 2rem;
  text-align: center;
}
.story-noscript p { margin: 0 0 1.25rem 0; }

/* ── Yunnan Toast ───────────────────────────────────────────── */
.yunnan-toast {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #1c1917;
  color: #fff;
  padding: 0.875rem 1.5rem;
  border-radius: 8px;
  font-size: 0.95rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  z-index: 9999;
  transition: none;
}
.yunnan-toast.toast-show {
  animation: toastFade 3.4s ease forwards;
}
@keyframes toastFade {
  0%   { opacity: 0; transform: translateX(-50%) translateY(20px); }
  12%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  75%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(20px); }
}
</style>

<script is:inline>
(function () {
  'use strict';

  /* ── Utils ──────────────────────────────────────────────── */
  function sleep(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

  /* ── Elements ───────────────────────────────────────────── */
  var section    = document.getElementById('story-section');
  var idle       = document.getElementById('story-idle');
  var curtain    = document.getElementById('story-curtain');
  var typewriter = document.getElementById('story-typewriter');

  if (!section || !idle || !curtain || !typewriter) return;

  /* ── Fade-in idle items via IntersectionObserver (re-triggers) */
  var storyItems = idle.querySelectorAll('[data-story-c-item]');
  var itemObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      } else {
        entry.target.classList.remove('is-visible');
      }
    });
  }, { threshold: 0.15 });
  storyItems.forEach(function (el, i) {
    el.style.transitionDelay = (i * 0.15) + 's';
    itemObs.observe(el);
  });

  /* ── Sentences ──────────────────────────────────────────── */
  var sentences = [
    { text: "We went overseas to study.", hold: 1800 },
    { text: "We thought we'd seen the world.", hold: 2000 },
    { text: "But there's a difference between passing through a place —", hold: 1600 },
    { text: "and letting it pass through you.", hold: 2200 },
    { text: "Eating where the locals eat.", hold: 1600 },
    { text: "Getting lost in streets that don't need you to understand them.", hold: 1800 },
    { text: "Falling into someone else's rhythm — and forgetting your own.", hold: 2400 },
    { text: "There's a version of the world you can only find by living in it.", hold: 3200, centre: true },
    { text: "We built this programme to share that feeling.", hold: 2000 },
    { text: "Not a tour. A way in.", hold: 2200 },
    { text: "Eighty UK students came to China with us.", hold: 1800 },
    { text: "Now we're in Canada.", hold: 1800 },
    { text: "Your turn.", hold: 0 }
  ];

  /* ── Credits roll state ─────────────────────────────────── */
  var twRunning  = false;
  var twPaused   = false;
  var twStarted  = false;
  var replayEl   = document.getElementById('story-replay');
  var scrollEl   = document.getElementById('story-b-scroll');
  var contentEl  = document.getElementById('story-b-content');
  var lineEls    = [];

  /* ── Position-based blur + opacity + clip-path ───────────── */
  function updateLineEffects() {
    if (!scrollEl) return;
    var scrollH = scrollEl.clientHeight;
    var centre  = scrollH * 0.5;
    var fadeZone = scrollH * 0.4;

    for (var i = 0; i < lineEls.length; i++) {
      var el = lineEls[i];
      var rect = el.getBoundingClientRect();
      var scrollRect = scrollEl.getBoundingClientRect();
      var elCentre = rect.top + rect.height / 2 - scrollRect.top;
      var dist = elCentre - centre; /* positive = below centre, negative = above */
      var absDist = Math.abs(dist);
      var ratio = Math.min(absDist / fadeZone, 1); /* 0=centre, 1=far */

      /* Below centre: approaching from bottom (entering) */
      /* Above centre: leaving upward (exiting) */
      var blur = ratio * 7;
      var opacity = Math.max(0, 1 - ratio * 1.1);

      el.style.filter = 'blur(' + blur.toFixed(1) + 'px)';
      el.style.opacity = opacity.toFixed(3);
    }
  }

  /* Promise-based smooth scroll with continuous blur updates */
  function smoothScrollToAsync(target, duration) {
    return new Promise(function (resolve) {
      if (!scrollEl) { resolve(); return; }
      var start = scrollEl.scrollTop;
      var diff  = target - start;
      if (Math.abs(diff) < 2) { updateLineEffects(); resolve(); return; }
      var startTime = null;

      function step(ts) {
        if (!startTime) startTime = ts;
        if (!twRunning) { resolve(); return; }
        var elapsed = ts - startTime;
        var progress = Math.min(elapsed / duration, 1);
        /* ease-in-out sine */
        var ease = 0.5 - 0.5 * Math.cos(Math.PI * progress);
        scrollEl.scrollTop = start + diff * ease;
        updateLineEffects();

        if (progress < 1) {
          requestAnimationFrame(step);
        } else {
          resolve();
        }
      }
      requestAnimationFrame(step);
    });
  }

  /* ── Continuous credits roll ────────────────────────────── */
  async function creditsRoll() {
    if (!scrollEl || !contentEl) return;

    /* Pre-render all sentences */
    lineEls = [];
    contentEl.innerHTML = '';
    for (var i = 0; i < sentences.length; i++) {
      var p = document.createElement('p');
      p.textContent = sentences[i].text;
      p.classList.add('story-line');
      if (sentences[i].centre) p.classList.add('is-centre');
      contentEl.appendChild(p);
      lineEls.push(p);
    }

    updateLineEffects();
    await sleep(600);

    /* Scroll each sentence to centre */
    for (var i = 0; i < lineEls.length; i++) {
      if (!twRunning) return;

      var el = lineEls[i];
      var s  = sentences[i];
      var scrollH = scrollEl.clientHeight;
      var target = el.offsetTop - (scrollH / 2) + (el.offsetHeight / 2);

      /* Scroll duration: first is slower (intro), rest scale with distance */
      var scrollDur = i === 0 ? 1400 : 1800;
      await smoothScrollToAsync(Math.max(0, target), scrollDur);
      if (!twRunning) return;

      /* Hold at centre for reading */
      if (s.hold > 0) {
        var holdStart = Date.now();
        while (Date.now() - holdStart < s.hold) {
          if (!twRunning) return;
          while (twPaused) {
            await sleep(100);
            if (!twRunning) return;
          }
          await sleep(50);
        }
      }
    }

    /* ── Finished — show replay ────────────────────────────── */
    twRunning = false;
    unlockScroll();
    await sleep(1000);
    if (replayEl) {
      replayEl.style.display = 'flex';
      replayEl.style.opacity = '0';
      requestAnimationFrame(function () {
        replayEl.style.transition = 'opacity 0.6s ease';
        replayEl.style.opacity = '0.6';
      });
    }
  }

  function startTypewriter() {
    contentEl.innerHTML = '';
    lineEls = [];
    if (scrollEl) scrollEl.scrollTop = 0;
    twRunning = true;
    lockScroll();
    creditsRoll();
  }

  /* ── Replay click handler ───────────────────────────────── */
  if (replayEl) {
    replayEl.addEventListener('click', function () {
      replayEl.style.transition = 'opacity 0.3s ease';
      replayEl.style.opacity = '0';
      setTimeout(function () {
        replayEl.style.display = 'none';
        startTypewriter();
      }, 350);
    });
    replayEl.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        replayEl.click();
      }
    });
  }

  /* ── Curtain completion ─────────────────────────────────── */
  var curtainDone = false;

  function completeCurtain() {
    if (curtainDone) return;
    curtainDone = true;

    curtain.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
    curtain.style.transform  = 'translateX(0)';

    setTimeout(function () {
      idle.style.display       = 'none';
      curtain.style.display    = 'none';
      typewriter.style.display = 'flex';

      if (!twStarted) {
        twStarted = true;
        setTimeout(function () {
          startTypewriter();
        }, 600);
      }
    }, 520);
  }

  function snapBack() {
    curtain.style.transition = 'transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
    curtain.style.transform  = 'translateX(-100%)';
  }

  /* ── Drag BACK from typewriter to idle ───────────────────── */
  function returnToIdle() {
    twRunning = false;
    unlockScroll();
    curtainDone = false;
    twStarted = false;
    if (replayEl) { replayEl.style.display = 'none'; replayEl.style.opacity = '0'; }
    contentEl.innerHTML = '';
    if (scrollEl) scrollEl.scrollTop = 0;

    /* Show curtain covering section, then slide it away to reveal idle */
    curtain.style.display = '';
    curtain.style.transition = 'none';
    curtain.style.transform = 'translateX(0)';
    idle.style.display = '';

    requestAnimationFrame(function () {
      typewriter.style.display = 'none';
      curtain.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      curtain.style.transform = 'translateX(100%)'; /* slide out to right */
      setTimeout(function () {
        curtain.style.transform = 'translateX(-100%)'; /* reset for next drag-in */
        curtain.style.transition = 'none';
      }, 520);
    });
  }

  /* Drag-back on typewriter: mouse */
  var backMouseStartX = null;
  var backMouseDown = false;

  typewriter.addEventListener('mousedown', function (e) {
    backMouseStartX = e.clientX;
    backMouseDown = true;
  });
  document.addEventListener('mousemove', function (e) {
    if (!backMouseDown || backMouseStartX === null) return;
    var dx = backMouseStartX - e.clientX; /* drag LEFT = positive */
    if (dx > section.offsetWidth * 0.15) {
      backMouseDown = false;
      backMouseStartX = null;
      returnToIdle();
    }
  });
  document.addEventListener('mouseup', function () {
    backMouseDown = false;
    backMouseStartX = null;
  });

  /* Drag-back on typewriter: touch */
  var backTouchStartX = null;
  var backTouchStartY = null;
  var backTouching = false;
  var backTouchLocked = false;

  typewriter.addEventListener('touchstart', function (e) {
    backTouchStartX = e.touches[0].clientX;
    backTouchStartY = e.touches[0].clientY;
    backTouching = true;
    backTouchLocked = false;
  }, { passive: true });

  typewriter.addEventListener('touchmove', function (e) {
    if (!backTouching || backTouchStartX === null) return;
    var dx = backTouchStartX - e.touches[0].clientX;
    var dy = Math.abs(e.touches[0].clientY - backTouchStartY);
    if (!backTouchLocked && Math.abs(dx) + dy > 10) {
      if (Math.abs(dx) > dy && dx > 0) {
        backTouchLocked = true;
      } else {
        backTouching = false;
        return;
      }
    }
    if (backTouchLocked && dx > section.offsetWidth * 0.15) {
      backTouching = false;
      backTouchStartX = null;
      returnToIdle();
    }
  }, { passive: true });

  typewriter.addEventListener('touchend', function () {
    backTouching = false;
    backTouchStartX = null;
    backTouchStartY = null;
    backTouchLocked = false;
  });

  /* ── Shared drag logic ──────────────────────────────────── */
  var THRESHOLD = 0.3; /* 30% = easier to trigger */

  function onDragMove(startX, clientX) {
    var dx       = Math.abs(clientX - startX);
    var sectionW = section.offsetWidth;
    var progress = Math.min(dx / sectionW, 1);
    /* translateX from -100% to 0 */
    var translate = -100 + (progress * 100);
    curtain.style.transform = 'translateX(' + translate + '%)';
    return progress;
  }

  function onDragEnd(progress) {
    if (curtainDone) return;
    if (progress >= THRESHOLD) {
      completeCurtain();
    } else {
      snapBack();
    }
  }

  /* ── Desktop mouse drag ─────────────────────────────────── */
  var mouseStartX = null;
  var mouseDown   = false;
  var mouseProgress = 0;

  idle.addEventListener('mousedown', function (e) {
    if (curtainDone) return;
    mouseStartX   = e.clientX;
    mouseDown     = true;
    mouseProgress = 0;
    curtain.style.transition = 'none';
  });

  document.addEventListener('mousemove', function (e) {
    if (!mouseDown || mouseStartX === null) return;
    mouseProgress = onDragMove(mouseStartX, e.clientX);
    if (mouseProgress >= 1) {
      mouseDown = false;
      mouseStartX = null;
      completeCurtain();
    }
  });

  document.addEventListener('mouseup', function (e) {
    if (!mouseDown) return;
    mouseDown = false;
    var prog = mouseStartX !== null
      ? Math.min(Math.max(e.clientX - mouseStartX, 0) / section.offsetWidth, 1)
      : mouseProgress;
    mouseStartX   = null;
    mouseProgress = 0;
    onDragEnd(prog);
  });

  /* ── Mac trackpad / wheel drag (two-finger swipe) ────────── */
  var wheelAccum = 0;
  var wheelTimer = null;
  var wheelActive = false;

  idle.addEventListener('wheel', function (e) {
    if (curtainDone) return;
    /* Only respond to horizontal scroll (Mac two-finger) */
    if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) return;
    e.preventDefault();

    if (!wheelActive) {
      wheelActive = true;
      curtain.style.transition = 'none';
    }

    wheelAccum += e.deltaX;
    var progress = Math.min(Math.max(wheelAccum / (section.offsetWidth * 0.3), 0), 1);
    var translate = -100 + (progress * 100);
    curtain.style.transform = 'translateX(' + translate + '%)';

    /* Auto-complete if past threshold */
    if (progress >= 1) {
      wheelAccum = 0;
      wheelActive = false;
      if (wheelTimer) clearTimeout(wheelTimer);
      completeCurtain();
      return;
    }

    /* Reset accumulator after inactivity */
    if (wheelTimer) clearTimeout(wheelTimer);
    wheelTimer = setTimeout(function () {
      if (curtainDone) return;
      var finalProgress = Math.min(Math.max(wheelAccum / (section.offsetWidth * 0.3), 0), 1);
      wheelAccum = 0;
      wheelActive = false;
      onDragEnd(finalProgress);
    }, 200);
  }, { passive: false });

  /* ── Mac trackpad drag-back from typewriter ─────────────── */
  var backWheelAccum = 0;
  var backWheelTimer = null;

  typewriter.addEventListener('wheel', function (e) {
    if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) return;
    /* Only respond to leftward swipe (negative deltaX) */
    if (e.deltaX >= 0) { backWheelAccum = 0; return; }

    backWheelAccum += Math.abs(e.deltaX);
    if (backWheelAccum > section.offsetWidth * 0.15) {
      backWheelAccum = 0;
      if (backWheelTimer) clearTimeout(backWheelTimer);
      returnToIdle();
      return;
    }

    if (backWheelTimer) clearTimeout(backWheelTimer);
    backWheelTimer = setTimeout(function () { backWheelAccum = 0; }, 300);
  }, { passive: true });

  /* ── Mobile touch drag ──────────────────────────────────── */
  var touchStartX   = null;
  var touchStartY   = null;
  var touching      = false;
  var touchProgress = 0;
  var touchLocked   = false; /* true = horizontal drag committed */

  idle.addEventListener('touchstart', function (e) {
    if (curtainDone) return;
    touchStartX   = e.touches[0].clientX;
    touchStartY   = e.touches[0].clientY;
    touching      = true;
    touchProgress = 0;
    touchLocked   = false;
    curtain.style.transition = 'none';
  }, { passive: true });

  idle.addEventListener('touchmove', function (e) {
    if (!touching || touchStartX === null) return;
    var dx = Math.abs(e.touches[0].clientX - touchStartX);
    var dy = Math.abs(e.touches[0].clientY - touchStartY);

    /* Decide direction on first significant move */
    if (!touchLocked && dx + dy > 10) {
      if (dx > dy) {
        touchLocked = true; /* horizontal — we own this gesture */
      } else {
        /* vertical scroll — abort drag */
        touching = false;
        touchStartX = null;
        return;
      }
    }

    if (touchLocked) {
      e.preventDefault(); /* stop vertical scroll while dragging */
      touchProgress = onDragMove(touchStartX, e.touches[0].clientX);
      if (touchProgress >= 1) {
        touching = false;
        touchStartX = null;
        completeCurtain();
      }
    }
  }, { passive: false });

  idle.addEventListener('touchend', function () {
    if (!touching) return;
    touching = false;
    var prog = touchProgress;
    touchStartX   = null;
    touchStartY   = null;
    touchProgress = 0;
    touchLocked   = false;
    onDragEnd(prog);
  });

  /* ── Scroll lock: keep section pinned while typewriter plays ── */
  var scrollLocked = false;
  var lockTimeout = null;

  function lockScroll() {
    scrollLocked = true;
    /* Snap section to top of viewport */
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function unlockScroll() {
    scrollLocked = false;
  }

  /* When locked, if user scrolls away, pull them back — unless they scroll past 50% */
  window.addEventListener('scroll', function () {
    if (!scrollLocked) return;
    var rect = section.getBoundingClientRect();
    var viewH = window.innerHeight;
    var visibleRatio = Math.max(0, Math.min(rect.bottom, viewH) - Math.max(rect.top, 0)) / viewH;

    if (visibleRatio < 0.5) {
      /* User scrolled past 50% — let them go */
      unlockScroll();
    } else if (Math.abs(rect.top) > 60) {
      /* Drifted but not past 50% — snap back */
      if (lockTimeout) clearTimeout(lockTimeout);
      lockTimeout = setTimeout(function () {
        if (scrollLocked) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }, 150);
    }
  }, { passive: true });

  /* ── IntersectionObserver: pause/resume typewriter ──────── */
  var sectionObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      twPaused = !entry.isIntersecting;
    });
  }, { threshold: 0.2 });
  sectionObs.observe(section);

  /* ── Misc: form placeholders ────────────────────────────── */
  var phAttr = 'pl' + 'ace' + 'holder';
  document.querySelectorAll('[data-ph]').forEach(function (el) {
    el.setAttribute(phAttr, el.getAttribute('data-ph') || '');
  });

  /* ── Yunnan toast ───────────────────────────────────────── */
  document.getElementById('yunnan-card')?.addEventListener('click', function () {
    var toast = document.getElementById('yunnan-toast');
    if (!toast) return;
    toast.classList.remove('toast-show');
    void toast.offsetWidth;
    toast.classList.add('toast-show');
    setTimeout(function () { toast.classList.remove('toast-show'); }, 3500);
  });
}());
</script>
