---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/v1/HeroSection.astro';
import DestinationCarousel from '../components/v1/DestinationCarousel.astro';
import DestinationGrid from '../components/v1/DestinationGrid.astro';
import Faq from '../components/v1/Faq.astro';
---
<Layout title="Explore China | Student Program" lang="en" alternateHref="/zh/" alternateLabel="中文" heroNav={true}>
  <HeroSection />

  <!-- ═══════════════════════════════════════════════════════════
       STORY SECTION — Version C look + Curtain + Version B Typewriter
  ════════════════════════════════════════════════════════════ -->
  <section id="story-section" class="story-c-section" aria-label="Our Story">

    <!-- STATE 1: Idle — Version C visual style -->
    <div class="story-c-inner" id="story-idle">
      <p class="story-c-item story-c-context" data-story-c-item>
        We're international students. Three years, 80+ participants, UK to China.
      </p>
      <p class="story-c-item story-c-hero" data-story-c-item>
        That feeling of your mind just&hellip; opening.
      </p>
      <p class="story-c-item story-c-closer" data-story-c-item>
        Now we're in Canada, and we'd love to bring you along.
      </p>
      <div class="story-drag-prompt story-c-item" id="story-drag-prompt" aria-hidden="true" data-story-c-item>
        <div class="story-drag-indicator">
          <div class="story-drag-line"></div>
          <div class="story-drag-circle">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#1c1917" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 10h12"/>
              <path d="M12 6l4 4-4 4"/>
            </svg>
          </div>
          <div class="story-drag-line"></div>
        </div>
        <p class="story-drag-prompt__text">Swipe to reveal</p>
      </div>
    </div>

    <!-- STATE 2: Curtain overlay -->
    <div class="story-curtain" id="story-curtain" aria-hidden="true"></div>

    <!-- STATE 3: Typewriter — Version B style -->
    <div class="story-b-section" id="story-typewriter" aria-live="polite">
      <div class="story-b-inner">
        <p class="story-b-eyebrow">Our Story</p>
        <div class="story-b-text-wrap" id="story-b-text">
          <span class="story-b-cursor" id="story-b-cursor" aria-hidden="true">|</span>
        </div>
        <!-- Replay button — hidden until typewriter finishes -->
        <div class="story-replay" id="story-replay" role="button" tabindex="0" aria-label="Read again">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M38 24c0 7.7-6.3 14-14 14S10 31.7 10 24 16.3 10 24 10c4.2 0 7.9 1.8 10.5 4.7"/>
            <polyline points="35,8 35,16 27,16"/>
          </svg>
          <p class="story-replay__text">Read again</p>
        </div>
      </div>
    </div>

    <!-- Noscript fallback: show Version C's 3 lines statically -->
    <noscript>
      <style>.story-c-inner { display: none !important; }</style>
      <div class="story-noscript">
        <p class="story-c-context">We're international students. Three years, 80+ participants, UK to China.</p>
        <p class="story-c-hero">That feeling of your mind just… opening.</p>
        <p class="story-c-closer">Now we're in Canada, and we'd love to bring you along.</p>
      </div>
    </noscript>
  </section>

  <DestinationCarousel />
  <DestinationGrid />

  <section id="itinerary" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Itinerary</p>
      <h2 class="section-title">10-Day Route Overview</h2>
      <div class="grid md:grid-cols-2 gap-8 mt-8">
        <a href="/trips/explore-china-2026-summer/" class="block bg-white p-6 border border-stone-200 hover:border-red-300 hover:shadow-md transition-all group">
          <h3 class="text-2xl font-semibold mb-2 group-hover:text-red-700 transition-colors">Beijing 10-Day Trip</h3>
          <p class="text-stone-600 leading-7">Great Wall, Forbidden City, student exchange activities, and a closing social night. A complete immersion in China's capital.</p>
          <span class="inline-block mt-4 text-red-700 font-medium text-sm">View itinerary →</span>
        </a>
        <button type="button" id="yunnan-card" class="text-left bg-white p-6 border border-stone-200 hover:border-amber-300 hover:shadow-md transition-all cursor-pointer w-full">
          <h3 class="text-2xl font-semibold mb-2">Yunnan 10-Day Trip</h3>
          <p class="text-stone-600 leading-7">Ancient towns, minority cultures, rice terraces, and mountain landscapes. A route through one of China's most visually distinct provinces.</p>
          <span class="inline-block mt-4 text-stone-400 font-medium text-sm">Coming soon →</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Toast notification -->
  <div id="yunnan-toast" role="alert" aria-live="polite" class="yunnan-toast">
    This itinerary is currently being planned. Stay tuned! / 该行程正在筹备中，敬请期待！
  </div>

  <Faq />

  <section id="apply" class="py-20">
    <div class="container">
      <p class="section-eyebrow">Apply</p>
      <h2 class="section-title">Start Your Application</h2>
      <form class="grid md:grid-cols-2 gap-4 mt-8">
        <input class="border border-stone-300 p-3 bg-white" aria-label="Name" data-ph="Name" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Email" data-ph="Email" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Phone" data-ph="Phone" />
        <input class="border border-stone-300 p-3 bg-white" aria-label="Current city" data-ph="Current city" />
        <textarea class="md:col-span-2 border border-stone-300 p-3 bg-white min-h-[120px]" aria-label="Your travel goals" data-ph="Your travel goals"></textarea>
        <button type="button" class="md:col-span-2 justify-self-start bg-red-700 text-white px-7 py-3 hover:bg-red-800 transition-colors">Submit Application</button>
      </form>
    </div>
  </section>
</Layout>

<style>
/* ══ Story Section: Version C + Curtain + Version B Typewriter ══════════════ */

/* ── Container ─────────────────────────────────────────────── */
.story-c-section {
  position: relative;
  min-height: 100vh;
  background: #fdfcfb;
  overflow: hidden;
  user-select: none;
  touch-action: manipulation; /* let JS handle drag direction */
}

/* ── STATE 1: Version C idle ────────────────────────────────── */
.story-c-inner {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  padding: 4rem 2rem;
  text-align: center;
  z-index: 1;
  cursor: grab;
}
.story-c-inner:active { cursor: grabbing; }

.story-c-item {
  margin: 0;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.story-c-item.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.story-c-context {
  font-size: 1rem;
  font-weight: 300;
  color: #78716c;
  line-height: 1.6;
}
@media (min-width: 768px) {
  .story-c-context { font-size: 1.125rem; }
}

.story-c-hero {
  font-size: clamp(1.875rem, 5vw, 3.75rem);
  font-weight: 600;
  color: #1c1917;
  line-height: 1.2;
}

.story-c-closer {
  font-size: 1rem;
  font-weight: 300;
  color: #78716c;
  line-height: 1.6;
}
@media (min-width: 768px) {
  .story-c-closer { font-size: 1.125rem; }
}

/* ── Drag prompt + indicator ─────────────────────────────────── */
.story-drag-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  margin: 1.5rem 0 0;
}
.story-drag-prompt__text {
  font-size: 0.8rem;
  color: #a8a09a;
  font-weight: 300;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0;
}
.story-drag-indicator {
  display: flex;
  align-items: center;
  gap: 0;
}
.story-drag-line {
  width: 48px;
  height: 1px;
  background: #d6d3d1;
}
.story-drag-circle {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid #d6d3d1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  animation: dragPulse 2.5s ease-in-out infinite;
  flex-shrink: 0;
}
.story-drag-circle svg {
  animation: dragArrow 2.5s ease-in-out infinite;
}
@keyframes dragPulse {
  0%, 100% { transform: scale(1); border-color: #d6d3d1; }
  50% { transform: scale(1.08); border-color: #a8a09a; }
}
@keyframes dragArrow {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(3px); }
}

/* ── STATE 2: Curtain ───────────────────────────────────────── */
.story-curtain {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #fdfcfb;
  transform: translateX(-100%);
  z-index: 3;
  will-change: transform;
  box-shadow: 6px 0 24px rgba(28, 25, 23, 0.12);
}

/* ── STATE 3: Typewriter — Version B ────────────────────────── */
.story-b-section {
  position: absolute;
  inset: 0;
  background: #fdfcfb;
  display: none; /* set to flex by JS when active */
  align-items: center;
  justify-content: center;
  z-index: 4;
}

.story-b-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  padding: 3rem 2rem;
  width: 100%;
}

.story-b-eyebrow {
  margin: 0;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #a8a09a;
  font-weight: 400;
}

.story-b-text-wrap {
  max-width: 38rem;
  width: 100%;
  text-align: center;
  font-size: clamp(1.1rem, 2.5vw, 1.5rem);
  font-weight: 300;
  color: #1c1917;
  line-height: 1.7;
  min-height: 3.5rem;
}

.story-b-cursor {
  display: inline;
  color: #78716c;
  font-weight: 300;
  animation: story-b-blink 1s step-end infinite;
}

@keyframes story-b-blink {
  50% { opacity: 0; }
}

/* ── Replay button ──────────────────────────────────────────── */
.story-replay {
  display: none; /* shown by JS after typewriter ends */
  flex-direction: column;
  align-items: center;
  gap: 0;
  cursor: pointer;
  opacity: 0;
  color: #a8a09a;
  transition: opacity 0.6s ease;
  padding: 1rem;
}
.story-replay svg {
  transition: transform 0.6s ease;
}
.story-replay:hover {
  opacity: 0.85 !important;
}
.story-replay:hover svg {
  transform: rotate(360deg);
}
.story-replay__text {
  margin: 0.75rem 0 0;
  font-size: 0.85rem;
  color: #a8a09a;
  letter-spacing: 0.1em;
  font-weight: 300;
}

/* ── Mobile adjustments ─────────────────────────────────────── */
@media (max-width: 767px) {
  .story-c-inner {
    gap: 2rem;
    padding: 3rem 1.5rem;
  }
  .story-c-hero {
    font-size: clamp(1.5rem, 6vw, 2.25rem);
  }
  .story-drag-line { width: 32px; }
  .story-drag-circle { width: 40px; height: 40px; }
  .story-b-text-wrap {
    font-size: clamp(1rem, 4vw, 1.25rem);
    line-height: 1.8;
    padding: 0 0.5rem;
    min-height: 4rem;
  }
}

/* ── Noscript fallback ──────────────────────────────────────── */
.story-noscript {
  display: none;
  max-width: 38rem;
  margin: 0 auto;
  padding: 8rem 2rem;
  text-align: center;
}
.story-noscript p { margin: 0 0 1.25rem 0; }

/* ── Yunnan Toast ───────────────────────────────────────────── */
.yunnan-toast {
  position: fixed;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #1c1917;
  color: #fff;
  padding: 0.875rem 1.5rem;
  border-radius: 8px;
  font-size: 0.95rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  z-index: 9999;
  transition: none;
}
.yunnan-toast.toast-show {
  animation: toastFade 3.4s ease forwards;
}
@keyframes toastFade {
  0%   { opacity: 0; transform: translateX(-50%) translateY(20px); }
  12%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  75%  { opacity: 1; transform: translateX(-50%) translateY(0); }
  100% { opacity: 0; transform: translateX(-50%) translateY(20px); }
}
</style>

<script is:inline>
(function () {
  'use strict';

  /* ── Utils ──────────────────────────────────────────────── */
  function sleep(ms) { return new Promise(function (r) { setTimeout(r, ms); }); }

  /* ── Elements ───────────────────────────────────────────── */
  var section    = document.getElementById('story-section');
  var idle       = document.getElementById('story-idle');
  var curtain    = document.getElementById('story-curtain');
  var typewriter = document.getElementById('story-typewriter');
  var textEl     = document.getElementById('story-b-text');
  var cursorEl   = document.getElementById('story-b-cursor');

  if (!section || !idle || !curtain || !typewriter || !textEl || !cursorEl) return;

  /* ── Fade-in idle items via IntersectionObserver (re-triggers) */
  var storyItems = idle.querySelectorAll('[data-story-c-item]');
  var itemObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      } else {
        entry.target.classList.remove('is-visible');
      }
    });
  }, { threshold: 0.15 });
  storyItems.forEach(function (el, i) {
    el.style.transitionDelay = (i * 0.15) + 's';
    itemObs.observe(el);
  });

  /* ── Sentences ──────────────────────────────────────────── */
  var sentences = [
    { text: "We're international students who moved to the UK and discovered something we didn't expect.", ms: 40 },
    { text: "The real version of a place only shows up when you slow down and actually live in it.", ms: 40 },
    { text: "Then we realised — there's a whole other world out there. Different ways of living. Different rhythms. Things you'd never question until somewhere does it completely differently.", ms: 40 },
    { text: "That feeling of your mind just... opening.", ms: 60, big: true },
    { text: "We've been chasing ways to share it ever since.", ms: 40 },
    { text: "Three years ago we started taking students from the UK to China. 80+ people came.", ms: 40 },
    { text: "Now we're here in Canada, and we'd love to bring you along.", ms: 40 }
  ];

  /* ── Typewriter state ───────────────────────────────────── */
  var twRunning = false;
  var twPaused  = false;
  var twStarted = false;
  var replayEl  = document.getElementById('story-replay');
  var textWrap  = document.querySelector('.story-b-text-wrap');

  async function typewriterPlay() {
    for (var i = 0; i < sentences.length; i++) {
      if (!twRunning) return;
      var s = sentences[i];

      var span = document.createElement('span');
      if (s.big) {
        span.style.fontSize   = 'clamp(1.4rem, 3vw, 1.875rem)';
        span.style.fontWeight = '400';
      }
      textEl.insertBefore(span, cursorEl);

      /* type characters */
      for (var j = 0; j < s.text.length; j++) {
        if (!twRunning) { span.remove(); return; }
        while (twPaused) {
          await sleep(100);
          if (!twRunning) { span.remove(); return; }
        }
        span.textContent += s.text[j];
        await sleep(s.ms);
      }

      /* pause 1.5 s after fully typed */
      await sleep(1500);
      if (!twRunning) { span.remove(); return; }

      /* fade out over 0.4 s */
      span.style.transition = 'opacity 0.4s ease';
      span.style.opacity    = '0';
      await sleep(420);
      if (!twRunning) { span.remove(); return; }

      /* clear + brief pause before next sentence */
      span.remove();
      await sleep(200);
    }

    /* ── Finished all sentences — show replay ─────────────── */
    twRunning = false;
    cursorEl.style.display = 'none';
    if (textWrap) {
      textWrap.style.transition = 'opacity 0.8s ease';
      textWrap.style.opacity = '0';
    }
    await sleep(900);
    if (replayEl) {
      replayEl.style.display = 'flex';
      replayEl.style.opacity = '0';
      requestAnimationFrame(function () {
        replayEl.style.transition = 'opacity 0.6s ease';
        replayEl.style.opacity = '0.6';
      });
    }
  }

  function startTypewriter() {
    /* clear any leftover text spans */
    var old = textEl.querySelectorAll('span:not(.story-b-cursor)');
    old.forEach(function (el) { el.remove(); });
    cursorEl.style.display = '';
    if (textWrap) {
      textWrap.style.transition = '';
      textWrap.style.opacity = '1';
    }
    twRunning = true;
    typewriterPlay();
  }

  /* ── Replay click handler ───────────────────────────────── */
  if (replayEl) {
    replayEl.addEventListener('click', function () {
      replayEl.style.transition = 'opacity 0.3s ease';
      replayEl.style.opacity = '0';
      setTimeout(function () {
        replayEl.style.display = 'none';
        startTypewriter();
      }, 350);
    });
    /* keyboard accessibility */
    replayEl.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        replayEl.click();
      }
    });
  }

  /* ── Curtain completion ─────────────────────────────────── */
  var curtainDone = false;

  function completeCurtain() {
    if (curtainDone) return;
    curtainDone = true;

    curtain.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
    curtain.style.transform  = 'translateX(0)';

    setTimeout(function () {
      idle.style.display       = 'none';
      curtain.style.display    = 'none';
      typewriter.style.display = 'flex';

      if (!twStarted) {
        twStarted = true;
        setTimeout(function () {
          startTypewriter();
        }, 600);
      }
    }, 520);
  }

  function snapBack() {
    curtain.style.transition = 'transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
    curtain.style.transform  = 'translateX(-100%)';
  }

  /* ── Shared drag logic ──────────────────────────────────── */
  var THRESHOLD = 0.3; /* 30% = easier to trigger */

  function onDragMove(startX, clientX) {
    var dx       = Math.abs(clientX - startX);
    var sectionW = section.offsetWidth;
    var progress = Math.min(dx / sectionW, 1);
    /* translateX from -100% to 0 */
    var translate = -100 + (progress * 100);
    curtain.style.transform = 'translateX(' + translate + '%)';
    return progress;
  }

  function onDragEnd(progress) {
    if (curtainDone) return;
    if (progress >= THRESHOLD) {
      completeCurtain();
    } else {
      snapBack();
    }
  }

  /* ── Desktop mouse drag ─────────────────────────────────── */
  var mouseStartX = null;
  var mouseDown   = false;
  var mouseProgress = 0;

  idle.addEventListener('mousedown', function (e) {
    if (curtainDone) return;
    mouseStartX   = e.clientX;
    mouseDown     = true;
    mouseProgress = 0;
    curtain.style.transition = 'none';
  });

  document.addEventListener('mousemove', function (e) {
    if (!mouseDown || mouseStartX === null) return;
    mouseProgress = onDragMove(mouseStartX, e.clientX);
    if (mouseProgress >= 1) {
      mouseDown = false;
      mouseStartX = null;
      completeCurtain();
    }
  });

  document.addEventListener('mouseup', function (e) {
    if (!mouseDown) return;
    mouseDown = false;
    var prog = mouseStartX !== null
      ? Math.min(Math.max(e.clientX - mouseStartX, 0) / section.offsetWidth, 1)
      : mouseProgress;
    mouseStartX   = null;
    mouseProgress = 0;
    onDragEnd(prog);
  });

  /* ── Mobile touch drag ──────────────────────────────────── */
  var touchStartX   = null;
  var touchStartY   = null;
  var touching      = false;
  var touchProgress = 0;
  var touchLocked   = false; /* true = horizontal drag committed */

  idle.addEventListener('touchstart', function (e) {
    if (curtainDone) return;
    touchStartX   = e.touches[0].clientX;
    touchStartY   = e.touches[0].clientY;
    touching      = true;
    touchProgress = 0;
    touchLocked   = false;
    curtain.style.transition = 'none';
  }, { passive: true });

  idle.addEventListener('touchmove', function (e) {
    if (!touching || touchStartX === null) return;
    var dx = Math.abs(e.touches[0].clientX - touchStartX);
    var dy = Math.abs(e.touches[0].clientY - touchStartY);

    /* Decide direction on first significant move */
    if (!touchLocked && dx + dy > 10) {
      if (dx > dy) {
        touchLocked = true; /* horizontal — we own this gesture */
      } else {
        /* vertical scroll — abort drag */
        touching = false;
        touchStartX = null;
        return;
      }
    }

    if (touchLocked) {
      e.preventDefault(); /* stop vertical scroll while dragging */
      touchProgress = onDragMove(touchStartX, e.touches[0].clientX);
      if (touchProgress >= 1) {
        touching = false;
        touchStartX = null;
        completeCurtain();
      }
    }
  }, { passive: false });

  idle.addEventListener('touchend', function () {
    if (!touching) return;
    touching = false;
    var prog = touchProgress;
    touchStartX   = null;
    touchStartY   = null;
    touchProgress = 0;
    touchLocked   = false;
    onDragEnd(prog);
  });

  /* ── IntersectionObserver: pause/resume typewriter ──────── */
  var sectionObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      twPaused = !entry.isIntersecting;
    });
  }, { threshold: 0.2 });
  sectionObs.observe(section);

  /* ── Misc: form placeholders ────────────────────────────── */
  var phAttr = 'pl' + 'ace' + 'holder';
  document.querySelectorAll('[data-ph]').forEach(function (el) {
    el.setAttribute(phAttr, el.getAttribute('data-ph') || '');
  });

  /* ── Yunnan toast ───────────────────────────────────────── */
  document.getElementById('yunnan-card')?.addEventListener('click', function () {
    var toast = document.getElementById('yunnan-toast');
    if (!toast) return;
    toast.classList.remove('toast-show');
    void toast.offsetWidth;
    toast.classList.add('toast-show');
    setTimeout(function () { toast.classList.remove('toast-show'); }, 3500);
  });
}());
</script>
