---
import Layout from '../layouts/Layout.astro';
import { aboutContent, site } from '../data/site';
---
<Layout
  title="About Explore China"
  description="Learn about the student-led Explore China program for Canada-based travelers and the team behind the route."
  lang="en"
  alternateHref="/zh/about"
  alternateLabel="中文"
  canonical="/about"
  minimalNav={true}
  darkNav={true}
>
  <section class="section card tone-sand" style="padding:34px;">
    <p class="pill">About</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:10px;">About Explore China</h1>
  </section>

  <section class="section" style="padding: 3rem 2rem 4rem;">
    <h2 style="font-size:clamp(22px,3.5vw,36px); font-weight:700; font-family:var(--font-display); line-height:1.2; margin-bottom:1rem;">{aboutContent.heroText}</h2>
    <p class="muted" style="max-width:680px; font-size:18px; line-height:1.75;">{aboutContent.story}</p>
  </section>

  <section class="section card tone-blue">
    <h2 class="section-title">The team</h2>
    <div class="grid cols-3">
      {aboutContent.team.map((member) => (
        <article class="card" style="background:#fff;">
          <p class="label">{member.role}</p>
          <h3>{member.name}</h3>
          <p class="muted">{member.bio}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section card tone-rose">
    <h2 class="section-title">Why we built this</h2>
    <p class="muted">{aboutContent.whoWeAre}</p>
  </section>

  <section class="section card" style="margin-bottom:36px;">
    <h2 class="section-title">Contact</h2>
    <p class="muted">Email: {site.email}</p>
    <p class="muted">Instagram: {site.instagram}</p>
    <p class="muted">WeChat: {site.wechat}</p>
  </section>
</Layout>
