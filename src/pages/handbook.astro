---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Participant Handbook — Explore China" lang="en" alternateHref="/zh/handbook" alternateLabel="中文" darkNav={true}>

  <div class="handbook-page">

    <!-- 1. Page Header -->
    <header class="handbook-header">
      <p class="handbook-header__eyebrow">Explore China 2026</p>
      <h1 class="handbook-header__title">Participant Handbook</h1>
      <p class="handbook-header__sub">Everything you need before departure — in one page.</p>
    </header>

    <!-- Section Nav -->
    <nav class="handbook-nav" aria-label="Handbook sections">
      <p class="handbook-nav__label">Jump to section</p>
      <ul class="handbook-nav__list">
        <li><a href="#checklist">Checklist</a></li>
        <li><a href="#entry">Entry</a></li>
        <li><a href="#vpn">VPN</a></li>
        <li><a href="#sim">SIM</a></li>
        <li><a href="#apps">Apps &amp; Payment</a></li>
      </ul>
    </nav>

    <!-- Critical Warning -->
    <div class="handbook-callout">
      <p><strong>⚠ Two rules you cannot skip:</strong></p>
      <ol>
        <li><strong>Install your VPN before you board.</strong> It cannot be downloaded inside China.</li>
        <li><strong>Turn VPN OFF when setting up Alipay / WeChat Pay.</strong> Verification will fail otherwise.</li>
      </ol>
    </div>

    <!-- 2. Quick Checklist (interactive) -->
    <section id="checklist" class="handbook-section">
      <h2>Pre-Departure Checklist</h2>
      <ul class="handbook-checklist" id="interactive-checklist">
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>Passport valid 6+ months beyond travel</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>Hotel booking + return flight confirmed</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>VPN installed &amp; tested</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>Airport tourist SIM researched</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>WeChat — downloaded, verified, card linked</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>Alipay — downloaded, verified, card linked</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>DiDi — downloaded</span></li>
        <li><button class="check-toggle" aria-label="Toggle checked" type="button"><span class="check-box" aria-hidden="true"></span></button><span>Some RMB cash as backup</span></li>
      </ul>
    </section>

    <!-- 3. Entry Requirements -->
    <section id="entry" class="handbook-section">
      <h2>Entry Requirements</h2>

      <div class="entry-card">
        <h3>🇨🇦 Canadian &amp; 🇬🇧 UK Passport</h3>
        <p>Visa-free entry for up to <strong>30 days</strong> (until Dec 31, 2026).</p>
        <p class="entry-need">At the border you need: passport (6+ months validity) · hotel booking · return flight.</p>
      </div>

      <div class="entry-card">
        <h3>Other Passports — 240-Hour Transit</h3>
        <p>Many passports qualify for <strong>240-hour (10-day) visa-free transit</strong>.</p>
        <div class="entry-detail">
          <p><strong>Key requirement:</strong> your entry city and exit city must be different. For example, fly into Shanghai and out of Beijing.</p>
          <p>Hong Kong and Macau count as separate destinations — so entering via Shanghai and exiting through Hong Kong is valid.</p>
        </div>
        <p class="entry-need">Verify your passport's eligibility before booking.</p>
      </div>

      <div class="handbook-links">
        <a class="handbook-link" href="https://ca.china-embassy.gov.cn/eng/zytz_0/202602/t20260216_11860601.htm" target="_blank" rel="noopener">Official visa-free policy (Chinese Embassy in Canada)</a>
      </div>
    </section>

    <!-- 4. VPN -->
    <section id="vpn" class="handbook-section">
      <h2>VPN</h2>
      <p>Google, Instagram, WhatsApp, and YouTube are blocked in China.</p>
      <p>Install and test your VPN <strong>before you board your flight</strong> — VPN apps and their websites are inaccessible inside China.</p>
    </section>

    <!-- 5. SIM -->
    <section id="sim" class="handbook-section">
      <h2>SIM Card</h2>

      <div class="sim-recommend">
        <span class="badge-recommended">Recommended</span>
        <h3>Airport Tourist SIM</h3>
        <p>Buy a tourist SIM card at the airport when you arrive (passport required). This is the best option because:</p>
        <ul class="handbook-list">
          <li><strong>International access</strong> — can access Google, YouTube, WhatsApp without VPN (confirm when purchasing)</li>
          <li><strong>Chinese phone number</strong> — needed for ordering food, booking DiDi, and app verification</li>
          <li><strong>Local data</strong> — stable connection for WeChat Pay and maps</li>
        </ul>
        <p class="sim-tip">💡 When buying, ask specifically: "Can this SIM access Google and WhatsApp?"</p>
      </div>

      <div class="sim-alt">
        <h3>Other options</h3>
        <div class="sim-alt-grid">
          <div>
            <strong>eSIM</strong>
            <p>Convenient (set up before you fly), but no Chinese phone number — limits DiDi and food delivery.</p>
          </div>
          <div>
            <strong>Carrier roaming</strong>
            <p>Easiest, usually bypasses firewall. Expensive for heavy use, no Chinese number.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Apps & Payment -->
    <section id="apps" class="handbook-section">
      <h2>Apps &amp; Payment</h2>
      <p>Download these before you land. <strong>Turn VPN off during setup.</strong></p>

      <div class="app-grid">
        <div class="app-item">
          <div class="app-item__header">
            <span class="app-item__icon">💬</span>
            <div>
              <div class="app-item__name">WeChat</div>
              <div class="app-item__tag">Chat + Payment + Group Comms</div>
            </div>
          </div>
          <ol class="app-item__steps">
            <li>Register with phone number</li>
            <li>Verify identity (passport)</li>
            <li>Link Visa / Mastercard</li>
          </ol>
        </div>

        <div class="app-item">
          <div class="app-item__header">
            <span class="app-item__icon">💳</span>
            <div>
              <div class="app-item__name">Alipay</div>
              <div class="app-item__tag">Payment at shops, restaurants, transit</div>
            </div>
          </div>
          <ol class="app-item__steps">
            <li>Register with phone number</li>
            <li>Verify identity (passport)</li>
            <li>Link Visa / Mastercard</li>
          </ol>
        </div>

        <div class="app-item">
          <div class="app-item__header">
            <span class="app-item__icon">🚗</span>
            <div>
              <div class="app-item__name">DiDi</div>
              <div class="app-item__tag">Ride-hailing (China's Uber)</div>
            </div>
          </div>
          <ol class="app-item__steps">
            <li>Download &amp; register</li>
            <li>Set language to English</li>
            <li>Link Alipay or add card</li>
          </ol>
        </div>
      </div>

      <p class="handbook-note">P2P transfers are restricted for foreign cards. Bring RMB cash for small vendors.</p>
    </section>

    <!-- 7. Coming soon -->
    <section class="handbook-section handbook-section--stub">
      <h2>Packing, Transport, Health &amp; Emergency</h2>
      <div class="stub-box">
        <span class="stub-icon">🔜</span>
        <p>Details will be added closer to departure.</p>
      </div>
    </section>

  </div>

</Layout>

<style>
  /* ── Callout ────────────────────────────────────────────── */
  .handbook-callout {
    max-width: 52rem;
    margin: 0 auto 2rem;
    padding: 1.25rem 1.5rem;
    background: #fef3c7;
    border-left: 4px solid #f59e0b;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    color: #78350f;
  }
  .handbook-callout ol {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
  }
  .handbook-callout li {
    margin-bottom: 0.25rem;
  }

  /* ── Interactive Checklist ──────────────────────────────── */
  .handbook-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }
  .check-toggle {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 1.6rem;
  }
  .check-toggle .check-box {
    pointer-events: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .check-toggle.is-checked .check-box {
    background: #16a34a;
    border-color: #16a34a;
  }
  .check-toggle.is-checked .check-box::after {
    content: '✓';
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  .check-toggle.is-checked + span {
    text-decoration: line-through;
    opacity: 0.5;
  }

  /* ── Entry cards ────────────────────────────────────────── */
  .entry-card {
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .entry-card h3 {
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
    color: #1c1917;
  }
  .entry-card p {
    font-size: 0.95rem;
    color: #44403c;
    margin: 0.3rem 0;
    line-height: 1.5;
  }
  .entry-need {
    font-size: 0.88rem !important;
    color: #78716c !important;
    margin-top: 0.5rem !important;
  }
  .entry-detail {
    margin: 0.75rem 0;
    padding: 0.75rem 1rem;
    background: #f5f5f4;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    color: #57534e;
  }
  .entry-detail p {
    font-size: 0.9rem;
    margin: 0.25rem 0;
  }

  /* ── SIM section ────────────────────────────────────────── */
  .sim-recommend {
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
    position: relative;
  }
  .sim-recommend h3 {
    font-size: 1.05rem;
    margin: 0.5rem 0 0.5rem;
    color: #1c1917;
  }
  .sim-recommend p {
    font-size: 0.95rem;
    color: #44403c;
    margin: 0.3rem 0;
  }
  .sim-recommend .handbook-list {
    margin: 0.5rem 0;
    padding-left: 1.25rem;
  }
  .sim-recommend .handbook-list li {
    font-size: 0.93rem;
    color: #44403c;
    margin-bottom: 0.35rem;
    line-height: 1.45;
  }
  .sim-tip {
    margin-top: 0.75rem !important;
    padding: 0.6rem 0.75rem;
    background: #ecfdf5;
    border-radius: 0.4rem;
    font-size: 0.88rem !important;
    color: #065f46 !important;
  }
  .sim-alt h3 {
    font-size: 0.95rem;
    color: #78716c;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .sim-alt-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .sim-alt-grid > div {
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    border-radius: 0.5rem;
    padding: 1rem;
  }
  .sim-alt-grid strong {
    font-size: 0.95rem;
    color: #1c1917;
  }
  .sim-alt-grid p {
    font-size: 0.88rem;
    color: #78716c;
    margin: 0.25rem 0 0;
    line-height: 1.4;
  }
  @media (max-width: 600px) {
    .sim-alt-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── App grid (compact) ─────────────────────────────────── */
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }
  @media (max-width: 700px) {
    .app-grid {
      grid-template-columns: 1fr;
    }
  }
  .app-item {
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  .app-item__header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .app-item__icon {
    font-size: 1.75rem;
    flex-shrink: 0;
  }
  .app-item__name {
    font-size: 1.05rem;
    font-weight: 600;
    color: #1c1917;
  }
  .app-item__tag {
    font-size: 0.8rem;
    color: #a8a29e;
    margin-top: 0.1rem;
  }
  .app-item__steps {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.88rem;
    color: #57534e;
    line-height: 1.5;
  }
  .app-item__steps li {
    margin-bottom: 0.2rem;
  }

  /* ── Misc ───────────────────────────────────────────────── */
  .handbook-list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.95rem;
    color: #44403c;
  }
  .handbook-list li {
    margin-bottom: 0.3rem;
  }
</style>

<script>
  /* Interactive checklist — toggle check on click */
  document.querySelectorAll('.check-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      btn.classList.toggle('is-checked');
    });
  });
</script>
