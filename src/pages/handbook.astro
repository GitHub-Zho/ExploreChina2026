---
import Layout from '../layouts/Layout.astro';
import { handbookSections, itinerary, currentTrip, handbookPrep, site } from '../data/site';
---
<Layout title="Explore China Handbook" lang="en" alternateHref="/zh/handbook" alternateLabel="中文" minimalNav={true}>
  <section id="guide" class="section card tone-sand" style="padding:34px;">
    <p class="pill">Participant Handbook</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:10px;">Explore China Handbook</h1>
    <p class="muted" style="max-width:860px; font-size:18px;">A participant-facing operations page for route expectations, support structure, and what to prepare before departure.</p>
    <div class="grid cols-3" style="margin-top:12px;">
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Route</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.subtitle}</p></div>
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Duration</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.duration}</p></div>
      <div class="card" style="padding:12px; background:#fff;"><p class="label" style="margin:0">Package</p><p style="margin:6px 0 0; font-weight:680;">{currentTrip.priceCad}</p></div>
    </div>
  </section>

  <section id="overview" class="section card tone-blue">
    <h2 class="section-title">Program intent</h2>
    <p class="muted" style="max-width:920px; line-height:1.9;">{handbookSections.intro}</p>
    <div style="margin-top:16px; display:flex; gap:10px; flex-wrap:wrap;">
      <a class="btn btn-secondary" href="/trips/explore-china-2026-summer">View the trip page</a>
      <a class="btn btn-primary" href="/trips/explore-china-2026-summer#register">Go to application</a>
    </div>
  </section>

  <section class="section grid cols-2">
    <article class="card tone-rose">
      <h2>Accommodation</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.accommodation}</p>
    </article>
    <article class="card tone-rose">
      <h2>Dietary requirements</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.dietary}</p>
    </article>
    <article class="card tone-blue">
      <h2>Language support</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.language}</p>
    </article>
    <article class="card tone-blue">
      <h2>Safety and coordination</h2>
      <p class="muted" style="line-height:1.9;">{handbookSections.safety}</p>
    </article>
  </section>

  <section id="itinerary" class="section card tone-dark">
    <h2>Full 10-day schedule</h2>
    <div class="grid cols-2">
      {itinerary.map((d) => (
        <article class="card" style="padding:12px; background:#fff; color:#151515; border-color:#ece7dd;">
          <p class="pill" style="margin-bottom:8px;">{d.day}</p>
          <h3 style="margin-bottom:6px;">{d.city} · {d.title}</h3>
          <p class="muted" style="margin:0; color:#545a60;">{d.plan}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section card tone-sand" style="margin-bottom:36px;">
    <h2 class="section-title">Pre-departure checklist</h2>
    <div class="grid cols-2">
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.beforeYouLeave.title}</h3>
        <p class="muted">{handbookPrep.beforeYouLeave.text}</p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.visa.title}</h3>
        <p class="muted">{handbookPrep.visa.text}</p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.payment.title}</h3>
        <p class="muted">{handbookPrep.payment.text}</p>
      </article>
      <article class="card" style="background:#fff;">
        <h3>{handbookPrep.sim.title}</h3>
        <p class="muted">{handbookPrep.sim.text}</p>
      </article>
      <article class="card" style="background:#fff; grid-column:1 / -1;">
        <h3>{handbookPrep.packList.title}</h3>
        <ul class="muted" style="line-height:1.8; padding-left:18px; margin:8px 0 0;">
          {handbookPrep.packList.items.map((item) => <li>{item}</li>)}
        </ul>
        <p style="margin-top:10px;"><a class="text-link" href="https://www.travelchina.org.cn/en" target="_blank">Travel China official resources ↗</a></p>
        <p><a class="text-link" href="https://www.china-briefing.com/news/china-visa-free-policies-complete-guide/" target="_blank">China visa policy explainer ↗</a></p>
      </article>
    </div>
    <p class="muted" style="margin-top:16px;">Questions before departure? Email {site.email} and we will point you to the right prep step.</p>
  </section>
</Layout>
