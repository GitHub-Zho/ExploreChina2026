---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Privacy Policy - Explore China"
  description="Read the Explore China privacy policy for application forms, contact information, and participant communication."
  lang="en"
  alternateHref="/zh/privacy"
  alternateLabel="中文"
  canonical="/privacy"
  minimalNav={true}
  darkNav={true}
>
  <section class="section card tone-sand" style="padding:34px;">
    <p class="pill">Privacy</p>
    <h1 style="font-size:clamp(36px,5vw,64px); margin-top:10px;">Privacy Policy</h1>
  </section>

  <section class="section card" style="margin-bottom:36px;">
    <h2 class="section-title">What we collect</h2>
    <p class="muted">When you submit an application or contact form, we may collect your name, email address, phone number, and trip-related preferences so we can reply and coordinate next steps.</p>
    <h2 class="section-title" style="margin-top:2rem;">How we use it</h2>
    <p class="muted">We use this information to review applications, answer questions, send participant updates, and improve the Explore China program experience.</p>
    <h2 class="section-title" style="margin-top:2rem;">Contact</h2>
    <p class="muted">If you have privacy questions, contact us at <a href="mailto:hello@explorationclub.ca">hello@explorationclub.ca</a>.</p>
  </section>
</Layout>
